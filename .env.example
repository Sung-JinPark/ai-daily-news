ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI embeddings (pipeline.embed, ZE1). Required in CI for the
# semantic-similarity build input; locally optional (embed/similarity
# steps skip or fail-loud without it). Set as the VOYAGE_API_KEY secret.
# VOYAGE_API_KEY=pa-...

# Google Search Console site verification. CI passes this to the site
# build as PUBLIC_GOOGLE_SITE_VERIFICATION (GOOGLE_SITE_VERIFICATION
# secret). Optional locally.
# GOOGLE_SITE_VERIFICATION=...

# Optional — private research corpus backup to Google Cloud Storage.
# Leave these blank to keep everything local. When set, running
# `python -m pipeline.research.gcs_sync` mirrors data/research_private/
# to gs://$GCS_BUCKET/$GCS_PREFIX. Requires: pip install google-cloud-storage.
# GCS_BUCKET=my-ai-research
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
# GCS_PREFIX=ai-daily-news/research_private

---
import Base from "~/layouts/Base.astro";
import { allWeeklyDigests } from "~/lib/loadData";

const digests = allWeeklyDigests();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base title="주간 다이제스트 — AI Daily News">
  <header class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">주간 다이제스트</h1>
    <p class="text-sm text-slate-600">
      매주 일요일 발행 · 지난 7일간 핵심 흐름을 한 페이지로.
      <a href={`${base}/weekly.xml`} class="ml-2 text-orange-600 hover:text-orange-800">RSS 구독</a>
    </p>
  </header>

  {digests.length === 0 ? (
    <p class="text-slate-500">첫 주간 다이제스트가 일요일에 발행됩니다.</p>
  ) : (
    <ul class="space-y-3">
      {digests.map((d) => (
        <li class="rounded-lg border border-slate-200 bg-white p-5 hover:shadow-md transition-shadow">
          <a href={`${base}/weekly/${d.week}`} class="block">
            <div class="flex items-baseline justify-between gap-3 mb-2 flex-wrap">
              <h2 class="text-lg font-semibold text-indigo-700">{d.week}</h2>
              <span class="text-xs text-slate-500">{new Date(d.generated_at).toLocaleDateString("ko-KR")}</span>
            </div>
            <p class="text-sm text-slate-700 line-clamp-3">{d.theme_recap_ko}</p>
            <p class="text-xs text-slate-500 mt-2">테마 {d.themes.length}개 · TOP {d.top_story_ids.length}건</p>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

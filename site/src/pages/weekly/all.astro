---
import Base from "~/layouts/Base.astro";
import { allWeeklyDigests, type WeeklyDigest } from "~/lib/loadData";

const digests = allWeeklyDigests();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function firstSentence(text: string): string {
  const m = text.match(/^.{20,140}?[.!?](?=\s|$)/);
  if (m) return m[0];
  return text.length > 100 ? text.slice(0, 100).trim() + "…" : text;
}

function dateLabel(d: WeeklyDigest) {
  return new Date(d.generated_at).toLocaleDateString("ko-KR", {
    timeZone: "Asia/Seoul",
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---
<Base title="전체 주간 다이제스트 — AI Daily News">
  <a href={`${base}/weekly`} class="kicker text-ink/55 hover:text-accent inline-block mb-5">← 주간 다이제스트</a>

  <header class="mb-10 pb-4 border-b-2 border-ink">
    <div class="kicker text-accent mb-2">Weekly Edition · Archive</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none mb-3">전체 주간 다이제스트</h1>
    <p class="kicker text-ink/55 tabular-nums">총 {String(digests.length).padStart(2, "0")}개 주차</p>
  </header>

  {digests.length === 0 ? (
    <p class="text-ink/50">아직 발행된 주간 다이제스트가 없습니다.</p>
  ) : (
    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {digests.map((d) => (
        <li>
          <a
            href={`${base}/weekly/${d.week}`}
            class="block h-full border border-ink/15 hover:border-accent bg-white hover:bg-accent/[0.03] transition-colors p-5 group relative"
          >
            <div class="flex items-baseline justify-between gap-3 mb-3">
              <h2 class="font-serif text-2xl sm:text-[1.7rem] font-black text-ink group-hover:text-accent transition-colors tabular-nums leading-none">{d.week}</h2>
              <span class="kicker text-ink/45 tabular-nums shrink-0">{dateLabel(d)}</span>
            </div>
            <p class="text-[14px] text-ink/75 leading-relaxed line-clamp-2 mb-3">{firstSentence(d.theme_recap_ko)}</p>
            <div class="flex items-center gap-2 text-[11px] tracking-kicker uppercase font-semibold">
              <span class="text-ink/45 tabular-nums">테마 {String(d.themes.length).padStart(2, "0")}</span>
              <span class="text-ink/20">·</span>
              <span class="text-ink/45 tabular-nums">TOP {String(d.top_story_ids.length).padStart(2, "0")}</span>
              <span class="ml-auto text-accent opacity-0 group-hover:opacity-100 transition-opacity">열기 →</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

---
import Base from "~/layouts/Base.astro";
import NewsTile from "~/components/NewsTile.astro";
import { allWeeklyDigests, articleById, type Article } from "~/lib/loadData";

export async function getStaticPaths() {
  return allWeeklyDigests().map((d) => ({
    params: { week: d.week },
    props: { digest: d },
  }));
}

const { digest } = Astro.props;
const lookup = articleById();

function resolve(ids: string[]): Article[] {
  const out: Article[] = [];
  for (const id of ids) {
    const a = lookup.get(id);
    if (a) out.push(a);
  }
  return out;
}

const topArticles = resolve(digest.top_story_ids);
const themesResolved = digest.themes.map((t) => ({
  name: t.name,
  summary_ko: t.summary_ko,
  articles: resolve(t.article_ids),
}));

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const genLabel = new Date(digest.generated_at).toLocaleString("ko-KR");
---
<Base
  title={`주간 다이제스트 ${digest.week} — AI Daily News`}
  description={digest.theme_recap_ko.slice(0, 200)}
>
  <div class="mb-6">
    <a href={`${base}/weekly`} class="text-sm text-blue-600 hover:text-blue-800">← 주간 목록</a>
  </div>

  <header class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-2">주간 다이제스트 <span class="text-indigo-600">{digest.week}</span></h1>
    <p class="text-sm text-slate-500">{genLabel} 생성 · 입력 {digest.n_input}건</p>
  </header>

  <section class="mb-12 rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-white p-6 sm:p-8 shadow-sm">
    <h2 class="text-lg font-semibold text-indigo-700 mb-3">이번 주 흐름</h2>
    <p class="text-base sm:text-lg leading-relaxed text-slate-900">{digest.theme_recap_ko}</p>
  </section>

  {themesResolved.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-bold text-slate-900 mb-4 border-b border-slate-200 pb-2">주요 테마</h2>
      <div class="space-y-8">
        {themesResolved.map((theme) => (
          <div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">#{theme.name}</h3>
            <p class="text-sm text-slate-700 mb-4">{theme.summary_ko}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {theme.articles.map((a) => <NewsTile article={a} size="sm" />)}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {topArticles.length > 0 && (
    <section class="mb-12">
      <h2 class="text-xl font-bold text-slate-900 mb-4 border-b border-slate-200 pb-2">이번 주 TOP {topArticles.length}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topArticles.map((a, i) => (
          <div class="relative">
            <span class="absolute -top-2 -left-2 z-10 px-2 py-0.5 rounded bg-rose-600 text-white text-xs font-bold">#{i + 1}</span>
            <NewsTile article={a} size="md" />
          </div>
        ))}
      </div>
    </section>
  )}
</Base>

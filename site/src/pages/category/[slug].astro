---
import Base from "~/layouts/Base.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import { CATEGORIES, loadDay, loadLatest } from "~/lib/loadData";

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const latest = loadLatest();
const day = latest?.latest_day ?? "";
const { articles } = day ? loadDay(day) : { articles: [] };
const filtered = articles
  .filter((a) => a.category === slug)
  .sort((a, b) => {
    if (b.importance_score !== a.importance_score) return b.importance_score - a.importance_score;
    return (b.published ?? "").localeCompare(a.published ?? "");
  });
const label = CATEGORIES[slug!] ?? slug;
---
<Base title={`${label} — AI Daily News`} updatedAt={latest?.updated_at}>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Category</div>
    <h1 class="font-serif text-4xl sm:text-5xl font-black text-ink leading-none mb-3">{label}</h1>
    <p class="kicker text-ink/55 tabular-nums">{day} · {String(filtered.length).padStart(2, "0")}건</p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-0">
    {filtered.map((a) => <ArticleCard article={a} />)}
  </div>

  {filtered.length === 0 && (
    <p class="text-ink/50">이 카테고리에 해당하는 오늘 기사가 없습니다.</p>
  )}
</Base>

---
import Base from "~/layouts/Base.astro";
import ThemeCard from "~/components/ThemeCard.astro";
import { allArchivedThemes, loadRollingThemes } from "~/lib/loadData";

const rolling = loadRollingThemes();
const archives = allArchivedThemes();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base
  title="테마 — AI Daily News"
  description="지난 7일간 자동 감지된 다중일 서사(narrative)와 과거 주별 흐름을 한 페이지로."
>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Themes · Cross-day narratives</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none">테마</h1>
    <p class="mt-3 text-[13px] text-ink/60">여러 스토리를 관통하는 서사 3~5개를 매일 감지하고, 매주 아카이빙합니다.</p>
  </header>

  {rolling && rolling.themes.length > 0 ? (
    <section class="mb-14">
      <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">이번 주 흐름 · {rolling.window_start} ~ {rolling.window_end}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-8">
        {rolling.themes.map((t) => <ThemeCard theme={t} />)}
      </div>
    </section>
  ) : (
    <p class="text-ink/50 mb-10">아직 감지된 테마가 없습니다. 다음 파이프라인 실행 이후 채워집니다.</p>
  )}

  {archives.length > 0 && (
    <section>
      <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">주별 아카이브</h2>
      <div class="space-y-12">
        {archives.map((wk) => (
          <div>
            <h3 class="kicker text-ink/55 mb-4 tabular-nums">{wk.week}</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-8">
              {wk.themes.map((t) => <ThemeCard theme={t} compact />)}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</Base>

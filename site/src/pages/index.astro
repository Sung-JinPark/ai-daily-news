---
import Base from "~/layouts/Base.astro";
import HotFeature from "~/components/HotFeature.astro";
import HotSide from "~/components/HotSide.astro";
import NewsTile from "~/components/NewsTile.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import { hotnessScore, loadLatest, loadRecentDays, type Article } from "~/lib/loadData";

const latest = loadLatest();
const pool: Article[] = loadRecentDays(7);
const now = new Date();
const ranked = [...pool].sort((a, b) => hotnessScore(b, now) - hotnessScore(a, now));

// Normalize titles so re-published / re-indexed articles with the same
// headline but different URLs (e.g. /2026/06/15/slug vs /2026/06/16/slug)
// are collapsed to one entry.
function titleKey(t: string): string {
  return t
    .toLowerCase()
    .replace(/&#?\w+;/g, " ")          // strip HTML entities
    .replace(/[^\p{L}\p{N}]+/gu, " ")  // strip punctuation
    .replace(/\s+/g, " ")
    .trim();
}

// Dedupe by article id (URL hash), cluster_id, AND normalized title.
const seenIds = new Set<string>();
const seenClusters = new Set<string>();
const seenTitles = new Set<string>();
const unique: Article[] = [];
for (const a of ranked) {
  if (seenIds.has(a.id)) continue;
  if (a.cluster_id && seenClusters.has(a.cluster_id)) continue;
  const tk = titleKey(a.title_original || "");
  if (tk && seenTitles.has(tk)) continue;
  seenIds.add(a.id);
  if (a.cluster_id) seenClusters.add(a.cluster_id);
  if (tk) seenTitles.add(tk);
  unique.push(a);
}

const feature = unique[0];
const sideTop = unique.slice(1, 4);
const grid = unique.slice(4, 9);
const list = unique.slice(9, 14);
---
<Base title="HOT — AI Daily News" updatedAt={latest?.updated_at}>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Top Stories · 지난 7일</div>
    <h1 class="font-serif text-4xl sm:text-5xl font-black text-ink leading-none">Hot Ranking</h1>
  </header>

  {!feature && (
    <p class="text-ink/50">아직 충분한 데이터가 없습니다.</p>
  )}

  {feature && (
    <section class="mb-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">
        <div class="lg:col-span-2">
          <HotFeature article={feature} rank={1} />
        </div>
        <div class="space-y-0">
          <div class="kicker text-ink/50 mb-3 pb-2 border-b border-ink/15">다음 순위</div>
          {sideTop.map((a, i) => <HotSide article={a} rank={i + 2} />)}
        </div>
      </div>
    </section>
  )}

  {grid.length > 0 && (
    <section class="mb-14">
      <div class="kicker text-ink/60 mb-5 pb-3 border-b-2 border-ink">랭킹 05 — 09</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-2">
        {grid.map((a, i) => <NewsTile article={a} rank={i + 5} size="md" />)}
      </div>
    </section>
  )}

  {list.length > 0 && (
    <section>
      <div class="kicker text-ink/60 mb-5 pb-3 border-b-2 border-ink">랭킹 10 — 14</div>
      <ol class="divide-y divide-ink/15">
        {list.map((a, i) => (
          <li class="flex gap-5 items-start py-2" data-article-id={a.id} data-category={a.category}>
            <span class="shrink-0 font-serif font-black text-3xl text-ink/30 w-12 leading-none pt-7">
              {String(i + 10).padStart(2, "0")}
            </span>
            <div class="flex-1 min-w-0">
              <ArticleCard article={a} />
            </div>
          </li>
        ))}
      </ol>
    </section>
  )}

</Base>

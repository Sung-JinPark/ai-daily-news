---
import Base from "~/layouts/Base.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import HeroCard from "~/components/HeroCard.astro";
import FilterBar from "~/components/FilterBar.astro";
import SearchBox from "~/components/SearchBox.astro";
import TrendingChips from "~/components/TrendingChips.astro";
import { allDays, loadDay, loadLatest } from "~/lib/loadData";

const latest = loadLatest();
const day = latest?.latest_day ?? "";
const { articles, highlights, trending } = day
  ? loadDay(day)
  : { articles: [], highlights: [], trending: [] };

const highlightIds = highlights; // already ordered by rank
const hero = articles.find((a) => a.id === highlightIds[0]);
const topRest = highlightIds.slice(1).map((id) => articles.find((a) => a.id === id)).filter(Boolean) as typeof articles;
const highlightSet = new Set(highlights);
const rest = articles.filter((a) => !highlightSet.has(a.id));

const sources = Array.from(
  new Map(articles.map((a) => [a.source_id, { id: a.source_id, name: a.source_name }])).values(),
).sort((a, b) => a.name.localeCompare(b.name));

const days = allDays();
---
<Base title="AI Daily News — 오늘의 글로벌 AI" updatedAt={latest?.updated_at}>
  {!day && (
    <div class="rounded-md border border-slate-200 bg-slate-50 p-6 text-slate-600">
      아직 수집된 데이터가 없습니다. GitHub Actions가 처음 실행되면 이곳에 결과가 표시됩니다.
    </div>
  )}

  {day && (
    <>
      <section class="mb-10">
        <div class="flex items-baseline justify-between mb-1 flex-wrap gap-2">
          <h1 class="text-3xl font-bold text-slate-900">오늘의 핵심 <span class="text-slate-500 text-2xl font-medium">{day}</span></h1>
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/hot`} class="text-sm text-blue-600 hover:text-blue-800">7일간 HOT 보기 →</a>
        </div>
        <p class="text-sm text-slate-600 mb-6">전 세계 AI 소식을 한국어 인사이트로 정리했습니다.</p>
        <TrendingChips items={trending} />
        {hero && <HeroCard article={hero} />}
        {topRest.length > 0 && (
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            {topRest.map((a) => <ArticleCard article={a} highlight={true} />)}
          </div>
        )}
      </section>

      <section>
        <h2 class="text-xl font-semibold mb-4 text-slate-900">전체 기사</h2>
        <SearchBox articles={articles} />
        <FilterBar sources={sources} days={days} currentDay={day} />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
          {rest.map((a) => (
            <div data-article-id={a.id}>
              <ArticleCard article={a} />
            </div>
          ))}
        </div>
      </section>
    </>
  )}
</Base>

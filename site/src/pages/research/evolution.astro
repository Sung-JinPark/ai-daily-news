---
import Base from "~/layouts/Base.astro";
import Sparkline from "~/components/Sparkline.astro";
import { entityTimeSeries, entityWeeklyDelta } from "~/lib/loadData";

// Z1: entity time-series is rendered per granularity + type filter at
// build time. Views live under stable URLs so search engines and
// notebooks can bookmark them.
const granularity = (Astro.url.searchParams.get("g") as "day" | "week" | "month") ?? "day";
const typeParam = Astro.url.searchParams.get("type");
const typeFilter =
  typeParam === "model" || typeParam === "lab" || typeParam === "tag" ? typeParam : undefined;

const { buckets, series } = entityTimeSeries(granularity, 20, typeFilter);
// D-1: coarse weekly movers — the public counterpart of the private
// velocity metrics. Raw 7-day-window count diffs only; the smoothed
// daily velocity/acceleration stays private per the boundary contract
// in research/README.md.
const weekly = entityWeeklyDelta(8);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const label = { day: "일별", week: "주별", month: "월별" }[granularity];
const typeLabel = typeFilter ? { model: "모델", lab: "랩", tag: "태그" }[typeFilter] : "전체";

function link(g: string, t: string | undefined): string {
  const url = new URL(`${base}/research/evolution`, "http://x");
  url.searchParams.set("g", g);
  if (t) url.searchParams.set("type", t);
  return `${url.pathname}?${url.searchParams.toString()}`;
}

// Convert per-entity series into the shape Sparkline expects (day+count).
function toSparkline(pts: { bucket: string; count: number }[]) {
  return pts.map((p) => ({ day: p.bucket, count: p.count }));
}

// Overall totals across all mentions for the header stat line.
const totalMentions = series.reduce((s, r) => s + r.total, 0);
---
<Base
  title="엔티티 시계열 — AI Daily News"
  description="아카이브 전체 기간에서 모델·랩·태그 언급이 어떻게 변해왔는지 파악."
>
  <a href={`${base}/research`} class="kicker text-ink/55 hover:text-accent inline-block mb-5">← 리서치 포털</a>

  <header class="mb-8 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Research · Evolution</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none">엔티티 시계열</h1>
    <p class="mt-3 text-[13px] text-ink/60">
      <code class="text-[12px] font-mono">data/aggregates/entity_mentions.jsonl</code>에서
      전 기간 언급을 집계해서 모델·랩·태그별 스파크라인으로 표시합니다. 신규 LLM 호출 0.
    </p>
    <p class="mt-2 kicker text-ink/50 tabular-nums">
      집계 대상 상위 {series.length}개 엔티티 · 총 {totalMentions.toLocaleString()}건 · 버킷 {buckets.length}개
    </p>
  </header>

  <div class="mb-8 flex flex-wrap items-center gap-3 text-[12px]" role="group" aria-label="집계 옵션">
    <span class="kicker text-ink/50">단위</span>
    <div class="flex border border-ink/25">
      {(["day", "week", "month"] as const).map((g) => (
        <a
          href={link(g, typeFilter)}
          class:list={[
            "px-3 py-1 kicker",
            g === granularity ? "bg-ink text-white" : "text-ink/70 hover:text-accent",
          ]}
          aria-current={g === granularity ? "page" : undefined}
        >
          {g === "day" ? "일별" : g === "week" ? "주별" : "월별"}
        </a>
      ))}
    </div>
    <span class="kicker text-ink/50 ml-4">엔티티</span>
    <div class="flex border border-ink/25">
      <a href={link(granularity, undefined)} class:list={["px-3 py-1 kicker", !typeFilter ? "bg-ink text-white" : "text-ink/70 hover:text-accent"]}>전체</a>
      <a href={link(granularity, "model")} class:list={["px-3 py-1 kicker", typeFilter === "model" ? "bg-ink text-white" : "text-ink/70 hover:text-accent"]}>모델</a>
      <a href={link(granularity, "lab")} class:list={["px-3 py-1 kicker", typeFilter === "lab" ? "bg-ink text-white" : "text-ink/70 hover:text-accent"]}>랩</a>
      <a href={link(granularity, "tag")} class:list={["px-3 py-1 kicker", typeFilter === "tag" ? "bg-ink text-white" : "text-ink/70 hover:text-accent"]}>태그</a>
    </div>
    <span class="ml-auto kicker text-ink/50 tabular-nums">현재: {label} · {typeLabel}</span>
  </div>

  {series.length === 0 ? (
    <p class="text-ink/60 text-[13px]">이 조합에는 데이터가 없습니다. 다른 단위·엔티티 조합을 선택해 보세요.</p>
  ) : (
    <div class="border-t border-ink/10">
      <div class="grid grid-cols-[minmax(0,1fr)_minmax(6rem,10rem)_minmax(0,2fr)_minmax(6rem,8rem)] gap-3 py-2 text-[10.5px] tracking-kicker uppercase font-semibold text-ink/50 border-b border-ink/10">
        <span>엔티티</span>
        <span class="tabular-nums text-right">총 언급</span>
        <span>추이 ({label})</span>
        <span class="tabular-nums text-right">피크</span>
      </div>
      {series.map((row) => {
        const typeBadge = row.entity_type === "model" ? "모델" : row.entity_type === "lab" ? "랩" : "태그";
        const typeColor = row.entity_type === "model" ? "text-accent" : row.entity_type === "lab" ? "text-emerald-700" : "text-ink/60";
        return (
          <div class="grid grid-cols-[minmax(0,1fr)_minmax(6rem,10rem)_minmax(0,2fr)_minmax(6rem,8rem)] gap-3 py-3 border-b border-ink/10 items-center">
            <div class="min-w-0 flex items-baseline gap-2">
              <span class={`kicker ${typeColor}`}>{typeBadge}</span>
              <span class="font-serif text-base font-bold text-ink truncate">{row.entity}</span>
            </div>
            <div class="text-right font-serif text-xl font-black text-ink tabular-nums">{row.total.toLocaleString()}</div>
            <div class="min-w-0">
              <Sparkline data={toSparkline(row.series)} height={30} ariaLabel={`${row.entity} ${label} 언급 추이`} />
            </div>
            <div class="text-right text-[12px] text-ink/70 tabular-nums">
              <span>{row.peak_bucket}</span>
              <span class="text-ink/40"> · </span>
              <span>{row.peak_count}건</span>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <section class="mt-14">
    <h2 class="kicker text-ink mb-2 pb-3 border-b-2 border-ink">주간 변화</h2>
    {weekly.gainers.length === 0 && weekly.losers.length === 0 ? (
      <p class="mt-3 text-ink/60 text-[13px]">
        {weekly.spanDays < 14
          ? "아직 14일치 데이터가 쌓이지 않아 주간 비교를 표시하지 않습니다."
          : "이번 윈도우에는 유의미한 변화가 없습니다."}
      </p>
    ) : (
      <>
        <p class="mt-3 mb-5 kicker text-ink/50 tabular-nums">
          기준일 {weekly.asOf} · 최근 7일 vs 직전 7일 · 원시 카운트(평활 없음)
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-8">
          {([
            ["상승", weekly.gainers],
            ["하강", weekly.losers],
          ] as const).map(([title, rows]) => (
            <div>
              <h3 class="kicker text-ink/60 mb-2">{title}</h3>
              <table class="w-full text-[12.5px] border-collapse">
                <thead>
                  <tr class="text-left text-[10.5px] tracking-kicker uppercase font-semibold text-ink/50 border-b border-ink/10">
                    <th class="py-2 pr-3">엔티티</th>
                    <th class="py-2 pr-3 text-right tabular-nums">최근 7일</th>
                    <th class="py-2 pr-3 text-right tabular-nums">직전 7일</th>
                    <th class="py-2 text-right tabular-nums">Δ</th>
                  </tr>
                </thead>
                <tbody>
                  {rows.map((e) => {
                    const badge = e.entity_type === "model" ? "모델" : e.entity_type === "lab" ? "랩" : "태그";
                    const color = e.entity_type === "model" ? "text-accent" : e.entity_type === "lab" ? "text-emerald-700" : "text-ink/60";
                    return (
                      <tr class="border-b border-ink/5 hover:bg-accent/[0.02]">
                        <td class="py-1.5 pr-3">
                          <span class={`kicker mr-1.5 ${color}`}>{badge}</span>
                          <span class="font-serif font-bold">{e.entity}</span>
                        </td>
                        <td class="py-1.5 pr-3 text-right tabular-nums">{e.recent}</td>
                        <td class="py-1.5 pr-3 text-right tabular-nums text-ink/60">{e.prior}</td>
                        <td class={`py-1.5 text-right tabular-nums font-semibold ${e.delta > 0 ? "text-accent" : "text-ink/70"}`}>
                          {e.delta > 0 ? `+${e.delta}` : e.delta}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          ))}
        </div>
      </>
    )}
  </section>
</Base>

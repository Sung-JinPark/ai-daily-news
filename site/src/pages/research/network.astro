---
import Base from "~/layouts/Base.astro";
import { cooccurrenceGraph, cooccurrenceWeeklyDelta } from "~/lib/loadData";

// Z2: read filter from ?scope so bookmarks remain stable across
// redeploys. The default "focus" view is model×lab because the R4
// filter for entity_cooccurrence.jsonl already restricts pairs to
// "at least one side is model or lab", so this is the cleanest slice.
const scope = Astro.url.searchParams.get("scope") ?? "focus";
const includeTypes =
  scope === "all"
    ? (["model", "lab", "tag"] as const)
    : scope === "labs"
      ? (["lab"] as const)
      : scope === "models"
        ? (["model"] as const)
        : (["model", "lab"] as const);

const graph = cooccurrenceGraph({ topNodes: 22, minWeight: 1, includeTypes: [...includeTypes] });
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// ---- Radial layout (pure static SVG, no D3) ----
const CX = 320;
const CY = 320;
const R = 240;
const N = graph.nodes.length;
const positions = new Map<string, { x: number; y: number; angle: number }>();
for (let i = 0; i < N; i++) {
  const angle = (i / Math.max(N, 1)) * Math.PI * 2 - Math.PI / 2; // start at top
  positions.set(graph.nodes[i].id, {
    x: CX + R * Math.cos(angle),
    y: CY + R * Math.sin(angle),
    angle,
  });
}

const maxWeight = Math.max(1, ...graph.edges.map((e) => e.weight));
function edgeWidth(w: number): number {
  return 0.6 + (Math.log2(w + 1) / Math.log2(maxWeight + 1)) * 3.2;
}
function edgeOpacity(w: number): number {
  return 0.15 + (w / maxWeight) * 0.55;
}

const TYPE_COLOR: Record<string, string> = {
  model: "#be1622",
  lab: "#059669",
  tag: "#6b7280",
};

function link(s: string): string {
  const url = new URL(`${base}/research/network`, "http://x");
  url.searchParams.set("scope", s);
  return `${url.pathname}?${url.searchParams.toString()}`;
}

const topEdges = graph.edges.slice(0, 30);
// D-1: coarse weekly pair movers — the public counterpart of the
// private network-evolution metrics. Raw 7-day-window weight diffs
// only; Louvain communities and their evolution stay private per the
// boundary contract in research/README.md.
const weekly = cooccurrenceWeeklyDelta(10);
---
<Base
  title="공동 언급 그래프 — AI Daily News"
  description="전 기간에 걸친 모델·랩·태그 공동 언급을 라디얼 그래프로 시각화."
>
  <a href={`${base}/research`} class="kicker text-ink/55 hover:text-accent inline-block mb-5">← 리서치 포털</a>

  <header class="mb-8 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Research · Network</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none">공동 언급 그래프</h1>
    <p class="mt-3 text-[13px] text-ink/60">
      <code class="text-[12px] font-mono">data/aggregates/entity_cooccurrence.jsonl</code>에서
      전 기간에 걸쳐 같은 클러스터에 함께 나타난 엔티티 페어를 집계했습니다. 각 페어의 두께는
      해당 조합이 관측된 기사 수(로그 스케일).
    </p>
    <p class="mt-2 kicker text-ink/50 tabular-nums">노드 {graph.nodes.length} · 엣지 {graph.edges.length} · 최대 가중치 {maxWeight}</p>
  </header>

  <div class="mb-6 flex flex-wrap items-center gap-3 text-[12px]" role="group" aria-label="그래프 범위">
    <span class="kicker text-ink/50">범위</span>
    <div class="flex border border-ink/25">
      {(["focus", "models", "labs", "all"] as const).map((s) => (
        <a
          href={link(s)}
          class:list={["px-3 py-1 kicker", scope === s ? "bg-ink text-white" : "text-ink/70 hover:text-accent"]}
          aria-current={scope === s ? "page" : undefined}
        >
          {s === "focus" ? "모델×랩 (기본)" : s === "models" ? "모델만" : s === "labs" ? "랩만" : "전체"}
        </a>
      ))}
    </div>
  </div>

  {graph.nodes.length === 0 ? (
    <p class="text-ink/60 text-[13px]">이 범위에는 엣지가 없습니다. 다른 범위를 선택해 보세요.</p>
  ) : (
    <>
      <section class="mb-14">
        <div class="w-full overflow-x-auto">
          <svg viewBox="0 0 640 640" class="mx-auto block" style="max-width:680px; width:100%;" role="img" aria-label="공동 언급 라디얼 그래프">
            <title>공동 언급 그래프 — 상위 {graph.nodes.length}개 노드, {graph.edges.length}개 엣지</title>
            <g stroke-linecap="round">
              {graph.edges.map((e) => {
                const pa = positions.get(e.a)!;
                const pb = positions.get(e.b)!;
                return (
                  <line
                    x1={pa.x}
                    y1={pa.y}
                    x2={pb.x}
                    y2={pb.y}
                    stroke="#0a0a0a"
                    stroke-width={edgeWidth(e.weight)}
                    stroke-opacity={edgeOpacity(e.weight)}
                  />
                );
              })}
            </g>
            <g>
              {graph.nodes.map((n) => {
                const p = positions.get(n.id)!;
                const r = 4 + Math.min(8, Math.sqrt(n.total_weight));
                return <circle cx={p.x} cy={p.y} r={r} fill={TYPE_COLOR[n.type]} />;
              })}
            </g>
            <g font-family="Noto Serif KR, serif" font-size="12">
              {graph.nodes.map((n) => {
                const p = positions.get(n.id)!;
                const outward = 22;
                const lx = CX + (R + outward) * Math.cos(p.angle);
                const ly = CY + (R + outward) * Math.sin(p.angle);
                const anchor = Math.cos(p.angle) > 0.3 ? "start" : Math.cos(p.angle) < -0.3 ? "end" : "middle";
                return (
                  <text
                    x={lx}
                    y={ly}
                    text-anchor={anchor}
                    dominant-baseline="middle"
                    fill="#0a0a0a"
                  >{n.id}</text>
                );
              })}
            </g>
          </svg>
        </div>
        <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-[10px] tracking-kicker uppercase font-semibold text-ink/60 justify-center">
          <span class="inline-flex items-center gap-1.5"><span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#be1622"></span>모델</span>
          <span class="inline-flex items-center gap-1.5"><span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#059669"></span>랩</span>
          <span class="inline-flex items-center gap-1.5"><span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#6b7280"></span>태그</span>
          <span class="text-ink/40">· 노드 반지름 = 총 가중치, 선 두께 = log(엣지 가중치)</span>
        </div>
      </section>

      <section>
        <h2 class="kicker text-ink mb-4 pb-3 border-b-2 border-ink">상위 페어 · 가중치 순</h2>
        <table class="w-full text-[12.5px] border-collapse">
          <thead>
            <tr class="text-left text-[10.5px] tracking-kicker uppercase font-semibold text-ink/50 border-b border-ink/10">
              <th class="py-2 pr-3">엔티티 A</th>
              <th class="py-2 pr-3">엔티티 B</th>
              <th class="py-2 pr-3 text-right tabular-nums">가중치</th>
              <th class="py-2 pr-3 text-right tabular-nums">클러스터 수</th>
            </tr>
          </thead>
          <tbody>
            {topEdges.map((e) => {
              const aColor = TYPE_COLOR[e.a_type];
              const bColor = TYPE_COLOR[e.b_type];
              return (
                <tr class="border-b border-ink/5 hover:bg-accent/[0.02]">
                  <td class="py-1.5 pr-3">
                    <span class="inline-block w-2 h-2 rounded-full mr-1.5 align-middle" style={`background:${aColor}`}></span>
                    <span class="font-serif font-bold">{e.a}</span>
                  </td>
                  <td class="py-1.5 pr-3">
                    <span class="inline-block w-2 h-2 rounded-full mr-1.5 align-middle" style={`background:${bColor}`}></span>
                    <span class="font-serif font-bold">{e.b}</span>
                  </td>
                  <td class="py-1.5 pr-3 text-right tabular-nums font-semibold">{e.weight}</td>
                  <td class="py-1.5 pr-3 text-right tabular-nums text-ink/60">{e.cluster_ids.length}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </section>

      <section class="mt-14">
        <h2 class="kicker text-ink mb-2 pb-3 border-b-2 border-ink">이번 주 페어 변화</h2>
        {weekly.pairs.length === 0 ? (
          <p class="mt-3 text-ink/60 text-[13px]">
            {weekly.spanDays < 14
              ? "아직 14일치 데이터가 쌓이지 않아 주간 비교를 표시하지 않습니다."
              : "이번 윈도우에 관측된 페어가 없습니다."}
          </p>
        ) : (
          <>
            <p class="mt-3 mb-4 kicker text-ink/50 tabular-nums">
              기준일 {weekly.asOf} · 최근 7일 vs 직전 7일 · 원시 공동 언급 횟수
            </p>
            <table class="w-full text-[12.5px] border-collapse">
              <thead>
                <tr class="text-left text-[10.5px] tracking-kicker uppercase font-semibold text-ink/50 border-b border-ink/10">
                  <th class="py-2 pr-3">엔티티 A</th>
                  <th class="py-2 pr-3">엔티티 B</th>
                  <th class="py-2 pr-3 text-right tabular-nums">최근 7일</th>
                  <th class="py-2 pr-3 text-right tabular-nums">Δ</th>
                  <th class="py-2">비고</th>
                </tr>
              </thead>
              <tbody>
                {weekly.pairs.map((p) => (
                  <tr class="border-b border-ink/5 hover:bg-accent/[0.02]">
                    <td class="py-1.5 pr-3">
                      <span class="inline-block w-2 h-2 rounded-full mr-1.5 align-middle" style={`background:${TYPE_COLOR[p.a_type]}`}></span>
                      <span class="font-serif font-bold">{p.a}</span>
                    </td>
                    <td class="py-1.5 pr-3">
                      <span class="inline-block w-2 h-2 rounded-full mr-1.5 align-middle" style={`background:${TYPE_COLOR[p.b_type]}`}></span>
                      <span class="font-serif font-bold">{p.b}</span>
                    </td>
                    <td class="py-1.5 pr-3 text-right tabular-nums font-semibold">{p.recent}</td>
                    <td class={`py-1.5 pr-3 text-right tabular-nums font-semibold ${p.delta > 0 ? "text-accent" : "text-ink/70"}`}>
                      {p.delta > 0 ? `+${p.delta}` : p.delta}
                    </td>
                    <td class="py-1.5">
                      {p.isNew && <span class="kicker text-[9px] px-1.5 py-0.5 bg-accent/10 text-accent">NEW</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </>
        )}
      </section>
    </>
  )}
</Base>

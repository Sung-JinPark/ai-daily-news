---
import Base from "~/layouts/Base.astro";
import NewsTile from "~/components/NewsTile.astro";
import { PLAYERS, articlesForPlayer, type Player } from "~/lib/loadPlayers";

export async function getStaticPaths() {
  return PLAYERS.map((p) => ({
    params: { id: p.id },
    props: { player: p },
  }));
}

const { player } = Astro.props as { player: Player };
const articles = articlesForPlayer(player, 30);

// Group by yyyy-mm-dd for a timeline feel.
const byDay = new Map<string, typeof articles>();
for (const a of articles) {
  const day = (a.published ?? a.fetched_at).slice(0, 10);
  const arr = byDay.get(day) ?? [];
  arr.push(a);
  byDay.set(day, arr);
}
const days = Array.from(byDay.keys()).sort().reverse();

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const initial = player.name.charAt(0);
---
<Base
  title={`${player.name} — AI Daily News`}
  description={`${player.name}의 최근 30일 글로벌 AI 뉴스 ${articles.length}건을 한국어 인사이트로 정리.`}
>
  <div class="mb-6">
    <a href={`${base}/players`} class="text-sm text-blue-600 hover:text-blue-800">← 전체 플레이어</a>
  </div>

  <header class="mb-10 flex items-start gap-4">
    <div
      class="shrink-0 w-16 h-16 rounded-xl flex items-center justify-center text-white text-3xl font-bold"
      style={`background-color: ${player.color}`}
    >{initial}</div>
    <div class="min-w-0">
      <h1 class="text-3xl font-bold text-slate-900 mb-1">{player.name}</h1>
      <p class="text-sm text-slate-600 leading-relaxed mb-2">{player.blurb}</p>
      <p class="text-xs text-slate-500">
        <a href={player.homepage} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800">{player.homepage} →</a>
        <span class="mx-2">·</span>
        최근 30일 {articles.length}건
      </p>
    </div>
  </header>

  {articles.length === 0 ? (
    <p class="text-slate-500">아직 이 플레이어의 기사가 없습니다. 다음 파이프라인 실행 이후 채워집니다.</p>
  ) : (
    <div class="space-y-10">
      {days.map((day) => (
        <section>
          <h2 class="text-sm font-semibold text-slate-500 mb-3 sticky top-16 bg-white/90 backdrop-blur py-1 z-[5]">{day}</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {byDay.get(day)!.map((a) => <NewsTile article={a} size="md" />)}
          </div>
        </section>
      ))}
    </div>
  )}
</Base>

---
import Base from "~/layouts/Base.astro";
import { PLAYERS, countsForPlayers } from "~/lib/loadPlayers";

const counts = countsForPlayers(30);
const sorted = [...PLAYERS].sort((a, b) => {
  const dc = (counts[b.id] ?? 0) - (counts[a.id] ?? 0);
  if (dc !== 0) return dc;
  return a.name.localeCompare(b.name);
});

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base
  title="플레이어 — AI Daily News"
  description="OpenAI, Anthropic, DeepMind, Meta AI 등 글로벌 AI 주요 랩·기업의 최근 30일 활동을 한 페이지로."
>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Players</div>
    <h1 class="font-serif text-4xl sm:text-5xl font-black text-ink leading-none mb-3">랩 · 기업</h1>
    <p class="kicker text-ink/55">최근 30일 보도 동향 · 활동량 순</p>
  </header>

  <ul class="divide-y divide-ink/15">
    {sorted.map((p) => {
      const c = counts[p.id] ?? 0;
      const initial = p.name.charAt(0);
      return (
        <li>
          <a
            href={`${base}/players/${p.id}`}
            class="flex items-center gap-5 py-5 hover:bg-accent/[0.02] -mx-4 px-4 group"
          >
            <div
              class="shrink-0 w-14 h-14 flex items-center justify-center text-white font-serif font-black text-2xl"
              style={`background-color: ${p.color}`}
            >{initial}</div>
            <div class="min-w-0 flex-1">
              <div class="flex items-baseline justify-between gap-3 mb-1">
                <h2 class="font-serif text-xl font-bold text-ink group-hover:text-accent transition-colors">{p.name}</h2>
                <span class={`kicker tabular-nums ${c > 0 ? "text-accent" : "text-ink/30"}`}>
                  {c > 0 ? `${String(c).padStart(2, "0")} 건` : "—"}
                </span>
              </div>
              <p class="text-sm text-ink/65 line-clamp-2 leading-relaxed">{p.blurb}</p>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</Base>

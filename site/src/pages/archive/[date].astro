---
import Base from "~/layouts/Base.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import FilterBar from "~/components/FilterBar.astro";
import SearchBox from "~/components/SearchBox.astro";
import TrendingChips from "~/components/TrendingChips.astro";
import { allDays, loadDay } from "~/lib/loadData";

export function getStaticPaths() {
  return allDays().map((date) => ({ params: { date } }));
}

const { date } = Astro.params;
const { articles, highlights, trending } = loadDay(date!);
const highlightSet = new Set(highlights);
const top = articles.filter((a) => highlightSet.has(a.id));
const rest = articles.filter((a) => !highlightSet.has(a.id));

const sources = Array.from(
  new Map(articles.map((a) => [a.source_id, { id: a.source_id, name: a.source_name }])).values(),
).sort((a, b) => a.name.localeCompare(b.name));
const days = allDays();
---
<Base title={`AI Daily News — ${date}`}>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Archive</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none mb-3 tabular-nums">{date}</h1>
    <p class="kicker text-ink/55 tabular-nums">전체 {String(articles.length).padStart(2, "0")}건</p>
  </header>

  <TrendingChips items={trending} />

  {top.length > 0 && (
    <section class="mb-12">
      <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">핵심 {String(top.length).padStart(2, "0")}건</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-0">
        {top.map((a) => <ArticleCard article={a} highlight={true} />)}
      </div>
    </section>
  )}

  <section>
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">전체</h2>
    <SearchBox articles={articles} />
    <FilterBar sources={sources} days={days} currentDay={date!} />
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-8 gap-y-0">
      {rest.map((a) => (
        <div data-article-id={a.id}>
          <ArticleCard article={a} />
        </div>
      ))}
    </div>
  </section>
</Base>

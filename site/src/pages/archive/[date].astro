---
import Base from "~/layouts/Base.astro";
import ArticleCard from "~/components/ArticleCard.astro";
import FilterBar from "~/components/FilterBar.astro";
import SearchBox from "~/components/SearchBox.astro";
import TrendingChips from "~/components/TrendingChips.astro";
import { allDays, loadDay } from "~/lib/loadData";

export function getStaticPaths() {
  return allDays().map((date) => ({ params: { date } }));
}

const { date } = Astro.params;
const { articles, highlights, trending } = loadDay(date!);
const highlightSet = new Set(highlights);
const top = articles.filter((a) => highlightSet.has(a.id));
const rest = articles.filter((a) => !highlightSet.has(a.id));

const sources = Array.from(
  new Map(articles.map((a) => [a.source_id, { id: a.source_id, name: a.source_name }])).values(),
).sort((a, b) => a.name.localeCompare(b.name));
const days = allDays();
---
<Base title={`AI Daily News — ${date}`}>
  <h1 class="text-2xl font-bold mb-1">{date} 아카이브</h1>
  <p class="text-sm text-slate-400 mb-5">전체 {articles.length}건</p>

  <TrendingChips items={trending} />

  {top.length > 0 && (
    <section class="mb-10">
      <h2 class="text-lg font-semibold mb-3">핵심 {top.length}건</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        {top.map((a) => <ArticleCard article={a} highlight={true} />)}
      </div>
    </section>
  )}

  <section>
    <h2 class="text-lg font-semibold mb-3">전체</h2>
    <SearchBox articles={articles} />
    <FilterBar sources={sources} days={days} currentDay={date!} />
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      {rest.map((a) => (
        <div data-article-id={a.id}>
          <ArticleCard article={a} />
        </div>
      ))}
    </div>
  </section>
</Base>

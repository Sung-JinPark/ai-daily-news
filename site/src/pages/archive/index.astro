---
import Base from "~/layouts/Base.astro";
import { allDays, loadDay, loadLatest } from "~/lib/loadData";

const latest = loadLatest();
const days = allDays();
const stats = days.map((day) => {
  const { articles } = loadDay(day);
  return { day, count: articles.length };
});
const total = stats.reduce((s, r) => s + r.count, 0);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base title="아카이브 — AI Daily News" updatedAt={latest?.updated_at}>
  <h1 class="text-2xl font-bold mb-1">아카이브</h1>
  <p class="text-sm text-slate-400 mb-6">{days.length}일 / 총 {total}건</p>

  {days.length === 0 ? (
    <p class="text-slate-400">아직 수집된 데이터가 없습니다.</p>
  ) : (
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {stats.map(({ day, count }) => (
        <li>
          <a
            href={`${base}/archive/${day}`}
            class="flex items-center justify-between border border-slate-200 hover:border-slate-400 hover:bg-slate-50 rounded-md p-4 transition"
          >
            <span class="font-medium text-slate-900">{day}</span>
            <span class="text-xs text-slate-500">{count}건</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

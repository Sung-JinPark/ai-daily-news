---
import Base from "~/layouts/Base.astro";
import { allDays, loadDay, loadLatest } from "~/lib/loadData";

const latest = loadLatest();
const days = allDays();
const stats = days.map((day) => {
  const { articles } = loadDay(day);
  return { day, count: articles.length };
});
const total = stats.reduce((s, r) => s + r.count, 0);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base title="아카이브 — AI Daily News" updatedAt={latest?.updated_at}>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Archive</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none mb-3">아카이브</h1>
    <p class="kicker text-ink/55 tabular-nums">{String(days.length).padStart(2, "0")}일 · 총 {String(total).padStart(2, "0")}건</p>
  </header>

  {days.length === 0 ? (
    <p class="text-ink/50">아직 수집된 데이터가 없습니다.</p>
  ) : (
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-0 divide-y divide-ink/15 sm:divide-y-0 sm:[&>li]:border-b sm:[&>li]:border-ink/15">
      {stats.map(({ day, count }) => (
        <li>
          <a
            href={`${base}/archive/${day}`}
            class="flex items-baseline justify-between py-4 group hover:text-accent"
          >
            <span class="font-serif text-xl font-bold text-ink group-hover:text-accent tabular-nums">{day}</span>
            <span class="kicker text-ink/55 tabular-nums">{String(count).padStart(2, "0")}건</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

---
import Base from "~/layouts/Base.astro";
import fs from "node:fs";
import path from "node:path";
import { allDays, allQuarterlyReports, loadLatest } from "~/lib/loadData";

const latest = loadLatest();
const days = allDays();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const DATA_ROOT = path.resolve(process.cwd(), "../data");

function countJsonlLines(rel: string): number {
  const p = path.join(DATA_ROOT, rel);
  if (!fs.existsSync(p)) return 0;
  let n = 0;
  for (const line of fs.readFileSync(p, "utf-8").split("\n")) {
    if (line.trim()) n++;
  }
  return n;
}

function countArticles(): number {
  let n = 0;
  for (const day of days) {
    const p = path.join(DATA_ROOT, day, "articles.json");
    if (!fs.existsSync(p)) continue;
    try {
      const arr = JSON.parse(fs.readFileSync(p, "utf-8"));
      if (Array.isArray(arr)) n += arr.length;
    } catch {}
  }
  return n;
}

function countCorpusDays(kind: string): number {
  const root = path.join(DATA_ROOT, "corpus");
  if (!fs.existsSync(root)) return 0;
  let n = 0;
  for (const d of fs.readdirSync(root)) {
    if (fs.existsSync(path.join(root, d, kind))) n++;
  }
  return n;
}

const stats = {
  articles: countArticles(),
  days: days.length,
  earliest: days[days.length - 1] ?? "—",
  latest_day: latest?.latest_day ?? "—",
  low_volume: !!latest?.low_volume,
  bodies_days: countCorpusDays("bodies.jsonl"),
  members_days: countCorpusDays("members.jsonl"),
  skipped_days: countCorpusDays("skipped.jsonl"),
  entity_mentions: countJsonlLines("aggregates/entity_mentions.jsonl"),
  tag_pairs: countJsonlLines("aggregates/tag_cooccurrence.jsonl"),
  entity_pairs: countJsonlLines("aggregates/entity_cooccurrence.jsonl"),
  source_health_rows: countJsonlLines("aggregates/source_health.jsonl"),
};

// Derive from the Actions env like astro.config/footer so forks and
// renames keep working; fall back to the canonical repo for local dev.
const REPO = import.meta.env.GITHUB_REPOSITORY || "Sung-JinPark/ai-daily-news";
const releasesUrl = `https://github.com/${REPO}/releases/latest`;
const releasesListUrl = `https://github.com/${REPO}/releases?q=archive-&expanded=true`;
const artifactUrl = `https://github.com/${REPO}/actions/workflows/daily.yml`;

const quarterlyReports = allQuarterlyReports();
---
<Base
  title="리서치 — AI Daily News"
  description="지난 일자별로 축적된 기사·본문·집계 데이터를 리서치와 프로덕트 용도로 다운로드·활용할 수 있는 페이지."
>
  <header class="mb-8 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Research Portal</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none">리서치 포털</h1>
    <p class="mt-3 text-[13px] text-ink/60">
      매일 축적되는 뉴스 코퍼스를 학술·시장·정책 리서치에 재활용할 수 있도록 SQLite 아카이브와 JSONL 집계를 공개합니다.
      최소한의 완결성을 갖춘 시점부터 정기 리포트도 함께 발행합니다.
    </p>
  </header>

  <section class="mb-14">
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">현 축적 상태</h2>
    <dl class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
      <div>
        <dt class="kicker text-ink/50">기사 총계</dt>
        <dd class="font-serif text-3xl font-black text-ink tabular-nums">{stats.articles.toLocaleString()}</dd>
      </div>
      <div>
        <dt class="kicker text-ink/50">축적 일수</dt>
        <dd class="font-serif text-3xl font-black text-ink tabular-nums">{stats.days}</dd>
      </div>
      <div>
        <dt class="kicker text-ink/50">시작일</dt>
        <dd class="font-serif text-lg font-bold text-ink tabular-nums">{stats.earliest}</dd>
      </div>
      <div>
        <dt class="kicker text-ink/50">최근일</dt>
        <dd class="font-serif text-lg font-bold text-ink tabular-nums">{stats.latest_day}</dd>
      </div>
      <div>
        <dt class="kicker text-ink/50">엔티티 언급</dt>
        <dd class="font-serif text-2xl font-bold text-ink tabular-nums">{stats.entity_mentions.toLocaleString()}</dd>
      </div>
      <div>
        <dt class="kicker text-ink/50">태그 페어</dt>
        <dd class="font-serif text-2xl font-bold text-ink tabular-nums">{stats.tag_pairs.toLocaleString()}</dd>
      </div>
      <div>
        <dt class="kicker text-ink/50">엔티티 페어</dt>
        <dd class="font-serif text-2xl font-bold text-ink tabular-nums">{stats.entity_pairs.toLocaleString()}</dd>
      </div>
      <div>
        <dt class="kicker text-ink/50">본문 저장 일수</dt>
        <dd class="font-serif text-2xl font-bold text-ink tabular-nums">{stats.bodies_days}</dd>
      </div>
    </dl>
  </section>

  <section class="mb-14">
    <div class="flex items-baseline justify-between mb-5 pb-3 border-b-2 border-ink">
      <h2 class="kicker text-ink">분기 리포트</h2>
      <a href={`${base}/reports`} class="kicker text-accent hover:underline">전체 리포트 →</a>
    </div>
    {quarterlyReports.length === 0 ? (
      <p class="text-[13px] text-ink/50">아직 발행된 분기 리포트가 없습니다. 다음 분기말 파이프라인 실행 이후 채워집니다.</p>
    ) : (
      <ul class="divide-y divide-ink/15">
        {quarterlyReports.slice(0, 3).map((r) => (
          <li class="py-4">
            <a href={`${base}/reports/${r.quarter}`} class="block group">
              <div class="kicker text-accent mb-1">{r.quarter} · {r.start} ~ {r.end}</div>
              <h3 class="font-serif text-lg font-bold text-ink group-hover:text-accent leading-snug mb-1">{r.title_ko}</h3>
              <p class="text-[13px] text-ink/65 leading-relaxed line-clamp-2">{r.exec_summary_ko}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <section class="mb-14">
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">다운로드</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href={releasesUrl} target="_blank" rel="noopener noreferrer" class="block border border-ink/15 hover:border-accent p-5 group">
        <div class="kicker text-accent mb-2">SQLite Archive · weekly</div>
        <h3 class="font-serif text-xl font-bold text-ink group-hover:text-accent mb-2">archive.db.gz — 최신 릴리스</h3>
        <p class="text-[13px] text-ink/65 leading-relaxed">
          모든 기사·본문·집계·주간 요약·예측·모델 팩트를 하나의 SQLite 파일로 통합. 매주 월요일 UTC에
          <a href={releasesListUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">GitHub Release</a>로 발행
          (익명 다운로드 가능 · 영속 URL). 매일 최신본은
          <a href={artifactUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Actions 아티팩트</a>
          (30일 보관, 로그인 필요)로도 제공.
        </p>
        <p class="mt-2 text-[12px] text-ink/50">로컬에서 <code class="text-[11px] font-mono">gunzip archive.db.gz</code> 후 <code class="text-[11px] font-mono">sqlite3</code>, pandas, DuckDB 등으로 바로 질의.</p>
      </a>
      <div class="border border-ink/15 p-5">
        <div class="kicker text-accent mb-2">JSONL streams · git</div>
        <h3 class="font-serif text-xl font-bold text-ink mb-2">Layer 1·3 append-only files</h3>
        <ul class="text-[13px] text-ink/70 leading-relaxed space-y-1">
          <li><code class="text-[12px] font-mono">data/corpus/YYYY-MM-DD/bodies.jsonl</code></li>
          <li><code class="text-[12px] font-mono">data/corpus/YYYY-MM-DD/members.jsonl</code></li>
          <li><code class="text-[12px] font-mono">data/corpus/YYYY-MM-DD/skipped.jsonl</code></li>
          <li><code class="text-[12px] font-mono">data/aggregates/entity_mentions.jsonl</code></li>
          <li><code class="text-[12px] font-mono">data/aggregates/tag_cooccurrence.jsonl</code></li>
          <li><code class="text-[12px] font-mono">data/aggregates/entity_cooccurrence.jsonl</code></li>
          <li><code class="text-[12px] font-mono">data/aggregates/source_health.jsonl</code></li>
        </ul>
        <p class="mt-3 text-[12px] text-ink/55">저장소 clone 후 바로 접근. <code class="font-mono">python -m pipeline.build_db</code> 재실행으로 SQLite 재생성.</p>
      </div>
    </div>
  </section>

  <section class="mb-14">
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">사이트 내 리서치 뷰</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href={`${base}/research/evolution`} class="block border border-ink/15 hover:border-accent p-5 group">
        <div class="kicker text-accent mb-2">Time Series</div>
        <h3 class="font-serif text-lg font-bold text-ink group-hover:text-accent mb-2">엔티티 시계열</h3>
        <p class="text-[13px] text-ink/65 leading-relaxed">전 기간 모델·랩·태그 언급을 일/주/월 단위 스파크라인으로. 신규 LLM 비용 0.</p>
      </a>
      <a href={`${base}/research/network`} class="block border border-ink/15 hover:border-accent p-5 group">
        <div class="kicker text-accent mb-2">Network</div>
        <h3 class="font-serif text-lg font-bold text-ink group-hover:text-accent mb-2">공동 언급 그래프</h3>
        <p class="text-[13px] text-ink/65 leading-relaxed">모델×랩·모델×태그 페어를 전 기간 그래프로. 클릭해서 관련 스토리로 이동.</p>
      </a>
      <a href={`${base}/research/completeness`} class="block border border-ink/15 hover:border-accent p-5 group">
        <div class="kicker text-accent mb-2">Corpus Health</div>
        <h3 class="font-serif text-lg font-bold text-ink group-hover:text-accent mb-2">코퍼스 완전성</h3>
        <p class="text-[13px] text-ink/65 leading-relaxed">skipped 로그 phase 분포 + 소스별 수집량 이력. 데이터 신뢰도 감사용.</p>
      </a>
    </div>
  </section>

  <section class="mb-14">
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">노트북 · 시작 자료</h2>
    <ul class="text-[13.5px] text-ink/75 leading-relaxed space-y-2">
      <li>
        <a href={`https://github.com/${REPO}/blob/main/notebooks/starter.ipynb`} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">notebooks/starter.ipynb</a>
        <span class="text-ink/50"> — archive.db 로드, 카테고리별 기사 수, 상위 태그, 매체 다양성.</span>
      </li>
    </ul>
  </section>

  <section class="mb-14">
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">스키마 요약</h2>
    <ul class="text-[13px] text-ink/70 space-y-2">
      <li><strong class="text-ink">articles</strong> — 대표 요약 기사. id · day · cluster_id · category · importance_score · tags(별도 테이블).</li>
      <li><strong class="text-ink">cluster_members</strong> — 같은 스토리를 다룬 매체 전원. dedupe.py 출력.</li>
      <li><strong class="text-ink">bodies</strong> — trafilatura로 추출한 원문 본문 (최대 6,000자).</li>
      <li><strong class="text-ink">skipped</strong> — 신선도·본문·LLM 실패 감사 로그.</li>
      <li><strong class="text-ink">entity_mentions</strong> — (day, entity, article_id) 시계열 언급 팩트.</li>
      <li><strong class="text-ink">tag_cooccurrence · entity_cooccurrence</strong> — 그래프 분석 엣지 리스트.</li>
      <li><strong class="text-ink">weekly_digests · themes · predictions · model_facts</strong> — LLM 파생 인사이트.</li>
      <li><strong class="text-ink">source_health</strong> — 매일 매체별 수집량 · 실패 사유.</li>
    </ul>
  </section>

  <section>
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">스키마 버전</h2>
    <p class="text-[13px] text-ink/70 leading-relaxed">
      JSON envelope 산출물 (<code class="text-[12px] font-mono">themes/rolling.json</code>,
      <code class="text-[12px] font-mono">predictions/registry.json</code>,
      <code class="text-[12px] font-mono">models/index.json</code>,
      <code class="text-[12px] font-mono">reports/*.json</code>,
      <code class="text-[12px] font-mono">corpus/manifest.json</code>,
      <code class="text-[12px] font-mono">cluster_continuity.json</code>)에는 <code class="text-[12px] font-mono">schema_version: 1</code> 필드가 있습니다.
      집계 JSONL 스트림(<code class="text-[12px] font-mono">aggregates/*.jsonl</code>)은
      본문에 필드를 넣는 대신 <code class="text-[12px] font-mono">data/aggregates/manifest.json</code>
      사이드카에 파일별 <code class="text-[12px] font-mono">schema_version · sha256 · lines · bytes</code>를 기록합니다.
      외부 소비자는 <em>파일을 열기 전에</em> 이 매니페스트를 확인해서 버전 호환성을 판단할 수 있습니다.
      현재 모든 스트림은 v1입니다.
    </p>
  </section>
</Base>

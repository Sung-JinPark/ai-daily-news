---
import fs from "node:fs";
import path from "node:path";
import Base from "~/layouts/Base.astro";

// Read pipeline/sources.yaml at build time and extract enabled sources via
// a simple regex pass (format is stable; full YAML parser overkill).
type SrcRow = { id: string; name: string; category: string; type: string };
const sourcesYaml = fs.readFileSync(
  path.resolve(process.cwd(), "../pipeline/sources.yaml"),
  "utf-8",
);
const sources: SrcRow[] = [];
{
  const blocks = sourcesYaml.split(/\n  - id:/).slice(1);
  for (const b of blocks) {
    const id = (b.match(/^\s*([^\s\n]+)/) ?? [])[1] ?? "";
    const name = (b.match(/name:\s*(.+)/) ?? [])[1]?.trim() ?? "";
    const category = (b.match(/category:\s*(\w+)/) ?? [])[1] ?? "";
    const type = (b.match(/type:\s*(\w+)/) ?? [])[1] ?? "";
    const enabled = !/enabled:\s*false/.test(b);
    if (enabled && id) sources.push({ id, name, category, type });
  }
}

const categoryLabel: Record<string, string> = {
  model_research: "모델/연구",
  business: "비즈니스/투자",
  policy: "정책/규제",
  product: "제품/툴",
  hardware: "하드웨어/인프라",
  community: "커뮤니티",
};
const grouped = new Map<string, SrcRow[]>();
for (const s of sources) {
  const arr = grouped.get(s.category) ?? [];
  arr.push(s);
  grouped.set(s.category, arr);
}
---
<Base
  title="이 사이트 소개 — AI Daily News"
  description="AI Daily News의 수집·요약·랭킹 파이프라인과 운영 방식을 설명합니다. 사람 손이 닿지 않고 매일 자동으로 갱신되는 글로벌 AI 뉴스 한국어 큐레이션 대시보드입니다."
>
  <article class="prose prose-slate max-w-none">
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3">이 사이트는 무엇인가요?</h1>
      <p class="text-base sm:text-lg text-slate-600 leading-relaxed">
        <strong>AI Daily News</strong>는 전 세계 AI 매체·연구소·아카이브를 매일 3회 자동 수집하여
        Claude Haiku 4.5로 한국어 요약·인사이트를 생성하는 정적 대시보드입니다.
        사람의 큐레이션 없이 100% 자동으로 운영됩니다.
      </p>
    </header>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-slate-900 mb-3">자동화 파이프라인</h2>
      <ol class="list-decimal list-outside ml-5 space-y-2 text-slate-700">
        <li><strong>수집(collect)</strong> — feedparser/httpx로 RSS·API·일부 스크랩 소스에서 신규 항목만 가져옵니다.</li>
        <li><strong>중복 제거(dedupe)</strong> — 제목 정규화 + SimHash로 같은 사건을 다룬 기사들을 클러스터링하고 대표 기사를 선정합니다.</li>
        <li><strong>본문 추출(extract)</strong> — trafilatura로 본문을 메모리에서만 추출합니다. <em>원문 전문은 디스크/레포에 저장하지 않습니다.</em></li>
        <li><strong>요약(summarize)</strong> — Claude Haiku 4.5에 본문 + 프롬프트 캐시를 보내 한국어 요약·인사이트·카테고리·중요도·태그 JSON을 생성합니다.</li>
        <li><strong>랭킹(rank)</strong> — 중요도·신선도·클러스터 크기로 가중 점수를 매겨 오늘의 핵심 5건을 선정합니다.</li>
        <li><strong>일일 다이제스트(digest)</strong> — 핵심 5건을 종합한 "오늘의 30초 브리핑"을 별도로 생성합니다.</li>
        <li><strong>주간 다이제스트(weekly)</strong> — 매주 일요일 KST 23시에 지난 7일을 종합한 주간 리캡을 생성합니다.</li>
        <li><strong>용어집 갱신(glossary)</strong> — 매주 일요일 본 사이트의 AI 용어 사전을 자동으로 확장합니다.</li>
        <li><strong>빌드·배포</strong> — Astro로 정적 HTML을 생성하고 GitHub Pages로 자동 배포합니다.</li>
      </ol>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-slate-900 mb-3">수집 소스 ({sources.length}개)</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {Array.from(grouped.entries()).map(([cat, items]) => (
          <div>
            <h3 class="text-sm font-semibold text-slate-700 mb-2">{categoryLabel[cat] ?? cat}</h3>
            <ul class="text-sm text-slate-600 space-y-1">
              {items.map((s) => <li>· {s.name} <span class="text-xs text-slate-400">({s.type})</span></li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-slate-900 mb-3">저작권 · 본문 정책</h2>
      <ul class="list-disc list-outside ml-5 space-y-2 text-slate-700">
        <li>원문 본문은 LLM 호출 시 메모리에만 사용하고 디스크·저장소·페이지 어디에도 남기지 않습니다.</li>
        <li>사이트에 노출되는 텍스트는 Claude Haiku 4.5가 새로 쓴 한국어 요약·인사이트뿐입니다. 원문 표현 직접 인용은 1문장 이내로 제한합니다.</li>
        <li>각 카드의 제목·이미지 출처는 원본 매체에 표기되어 있으며 "원문 보기" 링크로 즉시 이동합니다. 본 사이트는 원문 트래픽을 보조하는 메타-레이어입니다.</li>
        <li>저작권은 모두 각 매체에 있습니다. 본문 무단 재생산을 발견하시면 GitHub Issue로 알려주세요.</li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-slate-900 mb-3">운영비 · 모델</h2>
      <ul class="list-disc list-outside ml-5 space-y-2 text-slate-700">
        <li>LLM: <strong>Claude Haiku 4.5</strong> (Anthropic). 프롬프트 캐싱을 적극 사용해 시스템 프롬프트 재호출 비용을 최소화합니다.</li>
        <li>월 운영비: 약 $10~12 (LLM 호출), 호스팅 $0 (GitHub Pages).</li>
        <li>광고·트래커·구독 인프라 없음. 100% 무료 공개.</li>
      </ul>
    </section>

    <section class="mb-4">
      <h2 class="text-xl font-bold text-slate-900 mb-3">코드·연락</h2>
      <p class="text-slate-700">
        전체 파이프라인·사이트 코드는
        <a href="https://github.com/Sung-JinPark/ai-daily-news" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-800">GitHub 공개 저장소</a>에서 확인하실 수 있습니다.
        버그 제보·소스 제안은 Issues로 부탁드립니다.
      </p>
    </section>
  </article>
</Base>

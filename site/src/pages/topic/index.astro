---
import Base from "~/layouts/Base.astro";
import GlossarySection from "~/components/GlossarySection.astro";
import { loadTagsIndex } from "~/lib/loadData";

const idx = loadTagsIndex();
const entries = idx
  ? Object.entries(idx.tags).sort((a, b) => b[1].count - a[1].count)
  : [];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

function sizeClass(count: number, max: number): string {
  const ratio = count / Math.max(max, 1);
  if (ratio > 0.75) return "text-3xl font-black";
  if (ratio > 0.5) return "text-2xl font-bold";
  if (ratio > 0.25) return "text-xl font-semibold";
  if (ratio > 0.1) return "text-lg font-medium";
  return "text-base text-ink/55";
}
const maxCount = entries[0]?.[1].count ?? 1;
---
<Base title="토픽 — AI Daily News">
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Topics</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none mb-3">전체 토픽</h1>
    <p class="kicker text-ink/55">최근 30일 기사 태그 · 글자 크기 = 빈도{idx ? ` · 총 ${entries.length}개` : ""}</p>
  </header>

  {entries.length === 0 ? (
    <p class="text-ink/50">아직 태그 인덱스가 비어 있습니다. 다음 파이프라인 실행 이후 채워집니다.</p>
  ) : (
    <div class="flex flex-wrap gap-x-5 gap-y-3 items-baseline font-serif">
      {entries.map(([tag, info]) => (
        <a
          href={`${base}/topic/${encodeURIComponent(tag)}`}
          class={`${sizeClass(info.count, maxCount)} text-ink hover:text-accent transition-colors`}
          title={`${info.count}건`}
        >
          #{tag}
          <span class="text-[10px] text-ink/40 ml-0.5 tabular-nums tracking-normal font-sans">{info.count}</span>
        </a>
      ))}
    </div>
  )}

  <GlossarySection />
</Base>

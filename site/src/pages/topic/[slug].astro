---
import Base from "~/layouts/Base.astro";
import NewsTile from "~/components/NewsTile.astro";
import { loadTagsIndex, loadRecentDays, hotnessScore, type Article } from "~/lib/loadData";

export async function getStaticPaths() {
  const idx = loadTagsIndex();
  if (!idx) return [];
  return Object.entries(idx.tags).map(([tag, info]) => ({
    params: { slug: tag },
    props: { tag, count: info.count, categories: info.categories },
  }));
}

const { tag, count, categories } = Astro.props as { tag: string; count: number; categories: string[] };
const recent = loadRecentDays(30);
const articles: Article[] = recent
  .filter((a) => (a.tags ?? []).includes(tag))
  .sort((a, b) => hotnessScore(b) - hotnessScore(a));

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base
  title={`#${tag} — AI Daily News`}
  description={`'${tag}' 토픽의 최근 30일간 글로벌 AI 기사 ${count}건을 한국어 인사이트로 정리.`}
>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <a href={`${base}/topic`} class="kicker text-ink/55 hover:text-accent inline-block mb-3">← 전체 토픽</a>
    <div class="kicker text-accent mb-2">Topic</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none mb-3">#{tag}</h1>
    <p class="kicker text-ink/55">최근 30일 · {count}건 · {categories.join(" · ")}</p>
  </header>

  {articles.length === 0 ? (
    <p class="text-ink/50">아직 이 토픽의 기사가 없습니다.</p>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-2">
      {articles.map((a) => <NewsTile article={a} size="md" />)}
    </div>
  )}
</Base>

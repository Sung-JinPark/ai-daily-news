---
import Base from "~/layouts/Base.astro";
import ThemeCard from "~/components/ThemeCard.astro";
import { articleById, loadModelsIndex, loadPredictions, loadRollingThemes, loadTagsIndex } from "~/lib/loadData";
import { PLAYERS, countsForPlayers } from "~/lib/loadPlayers";

const rolling = loadRollingThemes();
const predictions = loadPredictions();
const models = loadModelsIndex();
const lookup = articleById();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Entities folded into the insights hub (nav consolidation): top
// players + compact topic cloud, with /entities kept as the deep view.
const playerCounts = countsForPlayers(30);
const topPlayers = [...PLAYERS]
  .map((p) => ({ player: p, count: playerCounts[p.id] ?? 0 }))
  .filter((r) => r.count > 0)
  .sort((a, b) => b.count - a.count)
  .slice(0, 6);
const tagsIdx = loadTagsIndex();
const topTags = tagsIdx
  ? Object.entries(tagsIdx.tags)
      .sort((a, b) => b[1].count - a[1].count)
      .slice(0, 16)
      .map(([tag, info]) => ({ tag, count: info.count }))
  : [];

const themesPreview = rolling?.themes.slice(0, 3) ?? [];

const recentResolved = predictions
  .filter((p) => p.status === "confirmed" || p.status === "contradicted")
  .sort((a, b) => (b.resolution_day ?? "").localeCompare(a.resolution_day ?? ""))
  .slice(0, 3);
const recentPending = predictions
  .filter((p) => p.status === "pending" || p.status === "still_pending")
  .sort((a, b) => b.day_made.localeCompare(a.day_made))
  .slice(0, 3);

const topModels = (models?.models ?? []).slice(0, 5);
// Quarterly reports live under /reports (single ownership) — the hub
// card below just points there.

const STATUS_LABEL: Record<string, string> = {
  pending: "대기",
  still_pending: "대기",
  confirmed: "확인됨",
  contradicted: "반박됨",
};
const STATUS_COLOR: Record<string, string> = {
  pending: "text-ink/50",
  still_pending: "text-ink/50",
  confirmed: "text-emerald-700",
  contradicted: "text-accent",
};
---
<Base
  title="인사이트 — AI Daily News"
  description="이번 주 흐름 · 예측 트래커 · 모델 비교를 한 페이지에서 확인하세요."
>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Insight Layer</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none">인사이트</h1>
    <p class="mt-3 text-[13px] text-ink/60">파이프라인이 자동 감지하는 다중일 서사 · 검증 가능한 예측 · 프론티어 모델 비교. 각 하위 페이지에서 전체 데이터를 볼 수 있습니다.</p>
  </header>

  <section class="mb-14">
    <div class="flex items-baseline justify-between mb-5 pb-3 border-b-2 border-ink">
      <h2 class="kicker text-ink">이번 주 흐름 · 테마</h2>
      <a href={`${base}/themes`} class="kicker text-accent hover:underline">전체 테마 →</a>
    </div>
    {themesPreview.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-8">
        {themesPreview.map((t) => <ThemeCard theme={t} compact />)}
      </div>
    ) : (
      <p class="text-ink/50 text-[13px]">감지된 테마가 없습니다. 다음 파이프라인 실행 이후 채워집니다.</p>
    )}
  </section>

  <section class="mb-14">
    <div class="flex items-baseline justify-between mb-5 pb-3 border-b-2 border-ink">
      <h2 class="kicker text-ink">예측 트래커</h2>
      <a href={`${base}/predictions`} class="kicker text-accent hover:underline">전체 예측 →</a>
    </div>

    {(recentResolved.length + recentPending.length) === 0 ? (
      <p class="text-ink/50 text-[13px]">아직 추적 중인 예측이 없습니다.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
        {recentResolved.length > 0 && (
          <div>
            <h3 class="kicker text-ink/50 mb-3">최근 판정</h3>
            <ul class="space-y-3">
              {recentResolved.map((p) => {
                const evidence = p.resolution_article_id ? lookup.get(p.resolution_article_id) : null;
                return (
                  <li>
                    <a href={`${base}/predictions#pred-${p.id}`} class="block group">
                      <div class="flex items-center gap-2 text-[10.5px] tracking-kicker uppercase font-semibold mb-1">
                        <span class={`${STATUS_COLOR[p.status] ?? "text-ink/50"} font-bold`}>{STATUS_LABEL[p.status]}</span>
                        <span class="text-ink/30">·</span>
                        <span class="text-ink/60">{p.who}</span>
                      </div>
                      <p class="text-[14px] text-ink leading-snug group-hover:text-accent break-words">{p.claim_ko}</p>
                      {evidence && <p class="mt-1 text-[11.5px] text-ink/50">근거: {evidence.title_original}</p>}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )}
        {recentPending.length > 0 && (
          <div>
            <h3 class="kicker text-ink/50 mb-3">대기 중</h3>
            <ul class="space-y-3">
              {recentPending.map((p) => (
                <li>
                  <a href={`${base}/predictions#pred-${p.id}`} class="block group">
                    <div class="flex items-center gap-2 text-[10.5px] tracking-kicker uppercase font-semibold mb-1">
                      <span class="text-ink/50 font-bold">대기</span>
                      <span class="text-ink/30">·</span>
                      <span class="text-ink/60">{p.who}</span>
                      {p.horizon !== "unspecified" && (
                        <>
                          <span class="text-ink/30">·</span>
                          <span class="text-ink/60">만기 {p.horizon}</span>
                        </>
                      )}
                    </div>
                    <p class="text-[14px] text-ink leading-snug group-hover:text-accent break-words">{p.claim_ko}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}
  </section>

  <section>
    <div class="flex items-baseline justify-between mb-5 pb-3 border-b-2 border-ink">
      <h2 class="kicker text-ink">모델 비교 · 최신 언급 순 TOP 5</h2>
      <a href={`${base}/compare`} class="kicker text-accent hover:underline">전체 표 →</a>
    </div>
    {topModels.length > 0 ? (
      <ul class="divide-y divide-ink/15">
        {topModels.map((m) => (
          <li class="py-3 flex flex-wrap items-baseline gap-x-4 gap-y-1">
            <span class="font-serif text-lg font-bold text-ink w-32 shrink-0">{m.model}</span>
            <span class="text-[13px] text-ink/75">{m.latest_version ?? "—"}</span>
            <span class="text-[11px] tracking-kicker uppercase font-semibold text-ink/50 tabular-nums">{m.latest_seen}</span>
            {m.top_benchmarks.length > 0 && (
              <span class="text-[12px] text-ink/60 ml-auto">
                {m.top_benchmarks.slice(0, 2).map((b) => `${b.name} ${b.score}`).join(" · ")}
              </span>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-ink/50 text-[13px]">아직 집계된 모델 데이터가 없습니다.</p>
    )}
  </section>

  <section class="mt-14 pt-8 border-t border-ink/15">
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink flex items-baseline justify-between">
      <span>엔티티 — 플레이어 & 토픽</span>
      <a href={`${base}/entities`} class="text-[11px] text-ink/50 hover:text-accent normal-case tracking-normal font-normal">전체 보기 →</a>
    </h2>
    {topPlayers.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
        {topPlayers.map(({ player, count }) => (
          <a href={`${base}/players/${player.id}`} class="block border border-ink/15 hover:border-accent p-3 group">
            <div class="kicker mb-1" style={`color:${player.color}`}>{player.name}</div>
            <div class="font-serif text-2xl font-black text-ink group-hover:text-accent tabular-nums">{count}</div>
            <div class="text-[10.5px] text-ink/50">최근 30일 기사</div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-ink/50 text-[13px] mb-6">아직 플레이어 활동 데이터가 없습니다.</p>
    )}
    {topTags.length > 0 && (
      <div class="flex flex-wrap gap-x-3 gap-y-1.5 items-baseline">
        {topTags.map(({ tag, count }) => (
          <a href={`${base}/topic/${encodeURIComponent(tag)}`} class="text-ink/70 hover:text-accent text-[13px]">
            #{tag} <span class="text-ink/40 text-[10.5px] tabular-nums">{count}</span>
          </a>
        ))}
      </div>
    )}
  </section>

  <section class="mt-14 pt-8 border-t border-ink/15">
    <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">더 깊이 · 리포트</h2>
    <a href={`${base}/reports`} class="block border border-ink/15 hover:border-accent p-5 group">
      <div class="kicker text-accent mb-1">분기 리포트</div>
      <h3 class="font-serif text-lg font-bold text-ink group-hover:text-accent mb-1">분기별 종합 리포트</h3>
      <p class="text-[13px] text-ink/65 leading-relaxed">
        분기마다 코퍼스 전체를 종합한 내러티브 리포트 — 주요 흐름·엔티티 변동·미결 예측을 한 번에.
      </p>
    </a>
  </section>
</Base>

---
import Base from "~/layouts/Base.astro";
import { allQuarterlyReports } from "~/lib/loadData";

const reports = allQuarterlyReports();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Base
  title="분기 리포트 — AI Daily News"
  description="지난 3개월 흐름을 종합한 분기별 리포트."
>
  <header class="mb-10 pb-4 border-b border-ink/15">
    <div class="kicker text-accent mb-2">Quarterly Reports</div>
    <h1 class="font-serif text-[1.8rem] sm:text-[2.4rem] font-black text-ink leading-none">분기 리포트</h1>
    <p class="mt-3 text-[13px] text-ink/60">주간 recap · 크로스데이 테마 · 엔티티 언급 · 대기 예측을 종합해 분기 흐름을 하나의 서사로 정리합니다.</p>
  </header>

  {reports.length === 0 ? (
    <p class="text-ink/50">아직 발행된 분기 리포트가 없습니다. 다음 분기말 파이프라인 실행 이후 채워집니다.</p>
  ) : (
    <ul class="divide-y divide-ink/15">
      {reports.map((r) => (
        <li class="py-6">
          <a href={`${base}/reports/${r.quarter}`} class="block group">
            <div class="kicker text-accent mb-1 flex items-center gap-2 flex-wrap">
              <span>{r.quarter} · {r.start} ~ {r.end}</span>
              {typeof r.coverage_ratio === "number" && r.coverage_ratio < 0.6 && (
                <span class="kicker text-accent bg-accent/10 px-1.5">부분 커버리지</span>
              )}
            </div>
            <h2 class="font-serif text-2xl font-black text-ink group-hover:text-accent mb-2 leading-snug break-words">{r.title_ko}</h2>
            <p class="text-[14.5px] text-ink/70 leading-relaxed line-clamp-3">{r.exec_summary_ko}</p>
            <p class="mt-2 kicker text-ink/45 tabular-nums">
              기사 {r.n_articles}건 · 활동 {r.n_days}일 · 서사 {r.top_narratives_ko.length}개
              {typeof r.coverage_ratio === "number" && typeof r.quarter_total_days === "number" && (
                <> · 커버리지 {Math.round(r.coverage_ratio * 100)}%</>
              )}
            </p>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>

---
import { CATEGORIES, type Article } from "~/lib/loadData";
import StoryLink from "~/components/StoryLink.astro";
interface Props {
  article: Article;
  rank: number;
}
const { article, rank } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const publishedLabel = article.published
  ? new Date(article.published).toLocaleDateString("ko-KR", { month: "long", day: "numeric" })
  : "";
---
<article
  class="flex gap-3 py-3 border-b border-ink/10 last:border-0 group"
  data-category={article.category}
  data-source={article.source_id}
>
  <div class="shrink-0 font-serif font-black text-2xl text-accent w-8 leading-none pt-1">
    {String(rank).padStart(2, "0")}
  </div>
  <a
    href={article.url}
    target="_blank"
    rel="noopener noreferrer"
    class="block w-24 sm:w-28 shrink-0 aspect-[4/3] bg-ink/5 overflow-hidden relative"
  >
    {article.image_url ? (
      <>
        <img
          src={article.image_url}
          alt=""
          referrerpolicy="no-referrer"
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div style="display:none" class="w-full h-full flex items-center justify-center font-serif text-ink/20 text-3xl">A</div>
      </>
    ) : (
      <div class="w-full h-full flex items-center justify-center font-serif text-ink/20 text-3xl">A</div>
    )}
  </a>
  <div class="flex-1 min-w-0 flex flex-col gap-1">
    <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-[10px] tracking-kicker uppercase font-semibold text-ink/60">
      <a href={`${base}/category/${article.category}`} class="text-accent hover:underline">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <span class="text-ink/30">·</span>
      <span class="min-w-0 break-words">{article.source_name}</span>
      {publishedLabel && (
        <>
          <span class="text-ink/30">·</span>
          <span class="normal-case tracking-normal font-normal text-ink/50">{publishedLabel}</span>
        </>
      )}
    </div>
    <div class="relative">
      <a
        href={article.url}
        target="_blank"
        rel="noopener noreferrer"
        class="peer block group/title"
        aria-label={article.title_original}
      >
        <h3 class="font-serif text-[15px] font-bold leading-snug text-ink break-words group-hover/title:text-accent transition-colors">
          {article.title_original}
        </h3>
      </a>
      {article.summary_ko && (
        <div
          role="tooltip"
          class="pointer-events-none invisible opacity-0 peer-hover:visible peer-hover:opacity-100 absolute z-30 top-full left-0 right-0 mt-2 p-3 bg-white border border-ink shadow-[4px_4px_0_0_rgba(10,10,10,0.08)] text-[12.5px] font-normal normal-case tracking-normal text-ink/85 leading-relaxed transition-opacity duration-150"
        >
          {article.summary_ko}
        </div>
      )}
    </div>
    <StoryLink article={article} size="sm" />
  </div>
</article>

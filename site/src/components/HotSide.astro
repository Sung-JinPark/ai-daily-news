---
import { CATEGORIES, type Article } from "~/lib/loadData";
interface Props {
  article: Article;
  rank: number;
}
const { article, rank } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<article
  class="rounded-lg overflow-hidden border border-slate-200 bg-white hover:shadow-md transition-shadow flex gap-3 group"
  data-category={article.category}
  data-source={article.source_id}
>
  <a
    href={article.url}
    target="_blank"
    rel="noopener noreferrer"
    class="block w-32 sm:w-36 shrink-0 aspect-[4/3] bg-slate-100 overflow-hidden relative"
  >
    {article.image_url ? (
      <img
        src={article.image_url}
        alt=""
        referrerpolicy="no-referrer"
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-300 text-3xl">📰</div>
    )}
    <span class="absolute top-1.5 left-1.5 px-1.5 py-0.5 rounded bg-rose-600 text-white text-[10px] font-bold">
      #{rank}
    </span>
  </a>
  <div class="flex-1 min-w-0 py-3 pr-3 flex flex-col gap-1.5">
    <div class="flex items-center gap-1.5 text-[11px] text-slate-500 flex-wrap">
      <a href={`${base}/category/${article.category}`} class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-700">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <span class="truncate">{article.source_name}</span>
    </div>
    <h3 class="text-sm font-semibold leading-snug text-slate-900 line-clamp-3">
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:underline">
        {article.title_original}
      </a>
    </h3>
  </div>
</article>

---
import type { Digest } from "~/lib/loadData";
interface Props {
  digest: Digest;
}
const { digest } = Astro.props;
---
<section class="rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-white p-5 sm:p-6 mb-8 shadow-sm">
  <div class="flex items-center gap-2 text-xs uppercase tracking-wider text-indigo-700 font-semibold mb-3">
    <span class="px-2 py-0.5 rounded bg-indigo-600 text-white">오늘의 30초 브리핑</span>
    <span class="px-2 py-0.5 rounded bg-indigo-100 text-indigo-700 normal-case tracking-normal">#{digest.theme_of_day}</span>
  </div>
  <p class="text-base sm:text-lg leading-relaxed text-slate-900 font-medium mb-4">{digest.tldr_ko}</p>
  <ul class="text-sm text-slate-700 leading-relaxed space-y-1.5 list-disc list-outside ml-5">
    {digest.bullets_ko.map((b) => <li>{b}</li>)}
  </ul>
</section>

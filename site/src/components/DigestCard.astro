---
import type { Digest } from "~/lib/loadData";
interface Props {
  digest: Digest;
}
const { digest } = Astro.props;
---
<section class="mb-12 border-l-4 border-accent pl-5 sm:pl-6">
  <div class="kicker text-accent mb-3">오늘의 30초 브리핑 · #{digest.theme_of_day}</div>
  <p class="font-serif text-xl sm:text-2xl leading-snug text-ink font-semibold mb-5">{digest.tldr_ko}</p>
  <ul class="text-[15px] text-ink/80 leading-relaxed space-y-2 list-disc list-outside ml-5 marker:text-accent">
    {digest.bullets_ko.map((b) => <li>{b}</li>)}
  </ul>
</section>

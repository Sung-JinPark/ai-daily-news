---
import { articleById, type Article, type WeeklyDigest } from "~/lib/loadData";

interface Props {
  digest: WeeklyDigest;
  heading?: string | null;
}

const { digest, heading = null } = Astro.props;
const lookup = articleById();

function resolve(ids: string[]): Article[] {
  const out: Article[] = [];
  for (const id of ids) {
    const a = lookup.get(id);
    if (a) out.push(a);
  }
  return out;
}

const topArticles = resolve(digest.top_story_ids);
const themeArticles = digest.themes.flatMap((t) => resolve(t.article_ids));

const seen = new Set<string>();
const pool: Article[] = [];
for (const a of [...topArticles, ...themeArticles]) {
  if (!seen.has(a.id)) {
    seen.add(a.id);
    pool.push(a);
  }
}

const tagFreq = new Map<string, number>();
for (const a of pool) {
  for (const tag of a.tags ?? []) {
    tagFreq.set(tag, (tagFreq.get(tag) ?? 0) + 1);
  }
}
const cloudData = Array.from(tagFreq.entries())
  .map(([text, value]) => ({ text, value }))
  .sort((a, b) => b.value - a.value)
  .slice(0, 40);
const cloudSet = new Set(cloudData.map((d) => d.text));

const coCount = new Map<string, number>();
function pairKey(a: string, b: string): string {
  return a < b ? `${a}\u0001${b}` : `${b}\u0001${a}`;
}
for (const a of pool) {
  const tags = (a.tags ?? []).filter((t) => cloudSet.has(t));
  for (let i = 0; i < tags.length; i++) {
    for (let j = i + 1; j < tags.length; j++) {
      const k = pairKey(tags[i], tags[j]);
      coCount.set(k, (coCount.get(k) ?? 0) + 1);
    }
  }
}
const linked = new Set<string>();
for (const k of coCount.keys()) {
  const [s, t] = k.split("\u0001");
  linked.add(s);
  linked.add(t);
}
const networkNodes = cloudData
  .filter((d) => linked.has(d.text))
  .map((d) => ({ id: d.text, value: d.value }));
const networkLinks = Array.from(coCount.entries()).map(([k, w]) => {
  const [s, t] = k.split("\u0001");
  return { source: s, target: t, value: w };
});

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Suffix per digest week so two viz blocks on the same page can coexist
// (today only one is rendered per page, but the IDs cost nothing).
const slug = digest.week.replace(/[^a-zA-Z0-9_-]/g, "_");
const cloudId = `viz-cloud-${slug}`;
const cloudStatusId = `viz-cloud-status-${slug}`;
const networkId = `viz-network-${slug}`;
const networkStatusId = `viz-network-status-${slug}`;

const vizData = {
  base,
  cloud: cloudData,
  nodes: networkNodes,
  links: networkLinks,
  cloudId,
  cloudStatusId,
  networkId,
  networkStatusId,
};

const hasNetwork = networkNodes.length >= 3 && networkLinks.length > 0;
const hasCloud = cloudData.length > 0;
---
{(hasNetwork || hasCloud) && heading && (
  <h2 class="kicker text-ink mb-5 pb-3 border-b-2 border-ink">{heading}</h2>
)}

{hasNetwork && (
  <section id="network" class="mb-10 scroll-mt-20">
    <div class="flex items-baseline justify-between gap-3 mb-3 flex-wrap">
      <h3 class="kicker text-accent">토픽 관계망</h3>
      <span class="text-[11px] text-ink/45 tabular-nums">노드 {String(networkNodes.length).padStart(2, "0")} · 엣지 {String(networkLinks.length).padStart(2, "0")}</span>
    </div>
    <p class="text-[13px] text-ink/55 mb-4">같은 기사에서 함께 언급된 태그를 연결. 노드 크기 = 등장 빈도, 선 굵기 = 동반 횟수. 드래그·휠 확대 가능, 노드 클릭 시 토픽 페이지로 이동.</p>
    <div id={networkId} class="w-full h-[500px] border border-ink/15 bg-ink/[0.02] relative">
      <span class="absolute inset-0 flex items-center justify-center text-ink/40 text-sm" id={networkStatusId}>로딩…</span>
    </div>
  </section>
)}

{hasCloud && (
  <section id="cloud" class="mb-14 scroll-mt-20">
    <div class="flex items-baseline justify-between gap-3 mb-3 flex-wrap">
      <h3 class="kicker text-accent">키워드 클라우드</h3>
      <span class="text-[11px] text-ink/45 tabular-nums">태그 {String(cloudData.length).padStart(2, "0")}</span>
    </div>
    <p class="text-[13px] text-ink/55 mb-4">이번 주 기사에 등장한 태그를 빈도순으로 시각화. 클릭하면 해당 토픽 페이지로 이동합니다.</p>
    <div id={cloudId} class="w-full h-72 sm:h-96 border border-ink/15 bg-ink/[0.02] relative">
      <span class="absolute inset-0 flex items-center justify-center text-ink/40 text-sm" id={cloudStatusId}>로딩…</span>
    </div>
  </section>
)}

{(hasNetwork || hasCloud) && (
  <>
    <script is:inline src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/d3-cloud@1.2.7/build/d3.layout.cloud.min.js"></script>
    <script is:inline define:vars={{ vizData }}>
      (function () {
        var data = vizData;

        function ready(check, max, cb) {
          if (check()) return cb();
          if (max <= 0) return;
          setTimeout(function () { ready(check, max - 1, cb); }, 50);
        }

        ready(
          function () {
            return window.d3 && (data.cloud.length === 0 || (window.d3.layout && window.d3.layout.cloud));
          },
          60,
          function () {
            if (data.nodes.length >= 3 && data.links.length) renderNetwork(data);
            if (data.cloud.length) renderCloud(data);
          }
        );

        function renderCloud(d) {
          var el = document.getElementById(d.cloudId);
          var status = document.getElementById(d.cloudStatusId);
          if (!el) return;
          var w = el.clientWidth || 800;
          var h = el.clientHeight || 320;
          var items = d.cloud;
          var max = items[0].value;
          var min = items[items.length - 1].value;
          var scale = d3.scaleSqrt().domain([min, max]).range([13, 48]);
          var layout = d3.layout.cloud()
            .size([w, h])
            .words(items.map(function (x) { return { text: x.text, size: scale(x.value), value: x.value }; }))
            .padding(4)
            .rotate(function () { return Math.random() < 0.25 ? 90 : 0; })
            .font('"Noto Serif KR", serif')
            .fontSize(function (x) { return x.size; })
            .on('end', draw);
          layout.start();

          function draw(words) {
            if (status) status.remove();
            var svg = d3.select(el).append('svg')
              .attr('viewBox', '0 0 ' + w + ' ' + h)
              .attr('width', '100%')
              .attr('height', '100%');
            svg.append('g')
              .attr('transform', 'translate(' + w / 2 + ',' + h / 2 + ')')
              .selectAll('text')
              .data(words)
              .enter()
              .append('text')
              .style('font-family', '"Noto Serif KR", serif')
              .style('font-weight', '700')
              .style('font-size', function (x) { return x.size + 'px'; })
              .style('cursor', 'pointer')
              .style('fill', function (_, i) {
                var palette = ['#be1622', '#1a1a1a', '#6b7280', '#be1622', '#1a1a1a'];
                return palette[i % palette.length];
              })
              .attr('text-anchor', 'middle')
              .attr('transform', function (x) { return 'translate(' + x.x + ',' + x.y + ')rotate(' + x.rotate + ')'; })
              .text(function (x) { return x.text; })
              .on('mouseover', function () { d3.select(this).style('fill', '#be1622').style('opacity', 0.85); })
              .on('mouseout', function () {
                var idx = words.indexOf(d3.select(this).datum());
                var palette = ['#be1622', '#1a1a1a', '#6b7280', '#be1622', '#1a1a1a'];
                d3.select(this).style('fill', palette[idx % palette.length]).style('opacity', 1);
              })
              .on('click', function (_, x) {
                window.location.href = d.base + '/topic/' + encodeURIComponent(x.text);
              })
              .append('title')
              .text(function (x) { return x.text + ' · ' + x.value + '건'; });
          }
        }

        function renderNetwork(d) {
          var el = document.getElementById(d.networkId);
          var status = document.getElementById(d.networkStatusId);
          if (!el) return;
          if (status) status.remove();
          var w = el.clientWidth || 800;
          var h = el.clientHeight || 500;
          var N = d.nodes.map(function (x) { return Object.assign({}, x); });
          var L = d.links.map(function (x) { return Object.assign({}, x); });
          var maxV = N.reduce(function (m, n) { return Math.max(m, n.value); }, 0);
          var minV = N.reduce(function (m, n) { return Math.min(m, n.value); }, Infinity);
          var r = d3.scaleSqrt().domain([Math.max(1, minV), Math.max(2, maxV)]).range([7, 28]);
          var maxW = L.reduce(function (m, l) { return Math.max(m, l.value); }, 1);
          var sw = d3.scaleLinear().domain([1, maxW]).range([0.6, 4]);

          var svg = d3.select(el).append('svg')
            .attr('viewBox', '0 0 ' + w + ' ' + h)
            .attr('width', '100%')
            .attr('height', '100%')
            .style('display', 'block');
          var g = svg.append('g');

          var sim = d3.forceSimulation(N)
            .force('link', d3.forceLink(L).id(function (x) { return x.id; }).distance(function (x) { return 90 - 7 * Math.min(x.value, 6); }).strength(0.6))
            .force('charge', d3.forceManyBody().strength(-180))
            .force('center', d3.forceCenter(w / 2, h / 2))
            .force('collide', d3.forceCollide().radius(function (x) { return r(x.value) + 6; }))
            // forceX/Y pulls every node toward center, so disconnected sub-hubs
            // settle close to each other without changing intra-cluster spacing.
            .force('x', d3.forceX(w / 2).strength(0.06))
            .force('y', d3.forceY(h / 2).strength(0.06));

          var link = g.append('g')
            .attr('stroke', '#1a1a1a')
            .attr('stroke-opacity', 0.18)
            .selectAll('line')
            .data(L)
            .enter().append('line')
            .attr('stroke-width', function (x) { return sw(x.value); });

          var node = g.append('g')
            .selectAll('g')
            .data(N)
            .enter().append('g')
            .style('cursor', 'pointer')
            .on('click', function (_, x) {
              window.location.href = d.base + '/topic/' + encodeURIComponent(x.id);
            })
            .on('mouseover', function () { d3.select(this).select('circle').attr('fill', '#1a1a1a'); })
            .on('mouseout', function () { d3.select(this).select('circle').attr('fill', '#be1622'); });

          node.append('circle')
            .attr('r', function (x) { return r(x.value); })
            .attr('fill', '#be1622')
            .attr('fill-opacity', 0.88)
            .attr('stroke', '#1a1a1a')
            .attr('stroke-width', 1);

          node.append('text')
            .attr('text-anchor', 'middle')
            .attr('dy', function (x) { return r(x.value) + 12; })
            .style('font-family', '"Noto Serif KR", serif')
            .style('font-weight', '700')
            .style('font-size', '11px')
            .style('fill', '#1a1a1a')
            .style('pointer-events', 'none')
            .style('paint-order', 'stroke')
            .style('stroke', 'rgba(255,255,255,0.9)')
            .style('stroke-width', '3px')
            .text(function (x) { return x.id; });

          node.append('title').text(function (x) { return x.id + ' · ' + x.value + '건'; });

          node.call(d3.drag()
            .on('start', function (e, x) { if (!e.active) sim.alphaTarget(0.3).restart(); x.fx = x.x; x.fy = x.y; })
            .on('drag', function (e, x) { x.fx = e.x; x.fy = e.y; })
            .on('end', function (e, x) { if (!e.active) sim.alphaTarget(0); x.fx = null; x.fy = null; }));

          svg.call(d3.zoom().scaleExtent([0.4, 3]).on('zoom', function (e) {
            g.attr('transform', e.transform);
          }));

          sim.on('tick', function () {
            link
              .attr('x1', function (x) { return x.source.x; })
              .attr('y1', function (x) { return x.source.y; })
              .attr('x2', function (x) { return x.target.x; })
              .attr('y2', function (x) { return x.target.y; });
            node.attr('transform', function (x) { return 'translate(' + x.x + ',' + x.y + ')'; });
          });
        }
      })();
    </script>
  </>
)}

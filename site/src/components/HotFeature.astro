---
import { CATEGORIES, loadGlossary, type Article } from "~/lib/loadData";
import { linkifyGlossary } from "~/lib/glossaryLinker";
interface Props {
  article: Article;
  rank?: number;
}
const { article, rank = 1 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const publishedLabel = article.published
  ? new Date(article.published).toLocaleString("ko-KR")
  : "";
const glossary = loadGlossary();
const summaryHtml = linkifyGlossary(article.summary_ko, glossary);
---
<article
  class="rounded-xl border border-slate-200 bg-white hover:shadow-md transition-shadow grid grid-cols-1 lg:grid-cols-5"
  data-category={article.category}
  data-source={article.source_id}
>
  <a
    href={article.url}
    target="_blank"
    rel="noopener noreferrer"
    class="block lg:col-span-3 aspect-[16/9] bg-slate-100 overflow-hidden rounded-t-xl lg:rounded-l-xl lg:rounded-tr-none relative group"
  >
    {article.image_url ? (
      <>
        <img
          src={article.image_url}
          alt=""
          referrerpolicy="no-referrer"
          loading="eager"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div style="display:none" class="w-full h-full flex items-center justify-center text-slate-300 text-6xl">📰</div>
      </>
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-300 text-6xl">📰</div>
    )}
    <span class="absolute top-3 left-3 px-2 py-0.5 rounded bg-rose-600 text-white text-xs font-bold">
      #{rank}
    </span>
  </a>

  <div class="lg:col-span-2 p-5 sm:p-6 flex flex-col gap-3">
    <div class="flex items-center gap-2 text-xs text-slate-500 flex-wrap">
      <a href={`${base}/category/${article.category}`} class="px-2 py-0.5 rounded bg-slate-100 hover:bg-slate-200 text-slate-700">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-slate-700 truncate">{article.source_name}</a>
      <span class="text-amber-500 ml-auto" title={`중요도 ${article.importance_score}`}>
        {"★".repeat(article.importance_score)}
      </span>
    </div>

    <h2 class="text-xl sm:text-2xl font-bold leading-snug text-slate-900">
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:underline">
        {article.title_original}
      </a>
    </h2>

    <div class="group/tip relative">
      <p class="text-sm text-slate-700 leading-relaxed line-clamp-4 cursor-default" set:html={summaryHtml}></p>
      <div class="invisible opacity-0 group-hover/tip:visible group-hover/tip:opacity-100
                  absolute left-0 top-full mt-2 z-[200] w-80
                  rounded-lg border border-slate-200 bg-white p-3 shadow-2xl
                  text-sm text-slate-700 leading-relaxed transition-opacity duration-150
                  select-text cursor-text
                  before:content-[''] before:absolute before:-top-2 before:left-0 before:right-0 before:h-2"
           set:html={summaryHtml}></div>
    </div>

    <div class="flex items-center justify-between text-xs text-slate-500 mt-auto pt-2">
      <span>
        {publishedLabel}
        {article.cluster_size > 1 && ` · ${article.cluster_size}개 매체`}
      </span>
      <a
        href={article.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-blue-600 hover:text-blue-800 font-medium"
      >
        원문 →
      </a>
    </div>
  </div>
</article>

---
import { CATEGORIES, loadGlossary, type Article } from "~/lib/loadData";
import { linkifyGlossary } from "~/lib/glossaryLinker";
interface Props {
  article: Article;
  highlight?: boolean;
}
const { article, highlight = false } = Astro.props;
const glossary = loadGlossary();
const summaryHtml = linkifyGlossary(article.summary_ko, glossary);
const publishedLabel = article.published
  ? new Date(article.published).toLocaleString("ko-KR")
  : "발행시각 미상";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<article
  class:list={[
    "rounded-lg border p-5 flex flex-col gap-3 transition-shadow hover:shadow-sm",
    highlight
      ? "border-amber-300 bg-amber-50/60"
      : "border-slate-200 bg-white",
  ]}
  data-category={article.category}
  data-source={article.source_id}
>
  <div class="flex items-center justify-between text-xs text-slate-500 flex-wrap gap-2">
    <span class="inline-flex items-center gap-2 flex-wrap">
      <a
        href={`${base}/category/${article.category}`}
        class="px-2 py-0.5 rounded bg-slate-100 text-slate-700 hover:bg-slate-200"
      >
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-slate-700">
        {article.source_name}
      </a>
      <span class="text-slate-300">·</span>
      <span>{publishedLabel}</span>
    </span>
    <span class="text-amber-500" title={`중요도 ${article.importance_score}`}>
      {"★".repeat(article.importance_score)}
    </span>
  </div>

  <h3 class="text-lg font-semibold leading-snug text-slate-900">
    {article.title_original}
  </h3>

  <p class="text-sm text-slate-700 leading-relaxed" set:html={summaryHtml}></p>

  {article.insights_ko?.length > 0 && (
    <ul class="text-sm text-slate-800 list-disc list-outside ml-5 space-y-1.5">
      {article.insights_ko.map((i) => <li>{i}</li>)}
    </ul>
  )}

  {(article.tags && article.tags.length > 0) && (
    <div class="flex flex-wrap gap-1">
      {article.tags.slice(0, 5).map((t) => (
        <a
          href={`${base}/topic/${encodeURIComponent(t)}`}
          class="text-[11px] px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-700 hover:bg-indigo-100"
        >#{t}</a>
      ))}
    </div>
  )}

  <div class="flex items-center justify-between pt-2 border-t border-slate-100">
    {article.also_covered_by?.length > 0 ? (
      <span class="text-xs text-slate-500">
        다른 매체 보도: {article.also_covered_by.slice(0, 3).join(", ")}
        {article.also_covered_by.length > 3 && ` 외 ${article.also_covered_by.length - 3}곳`}
      </span>
    ) : (
      <span></span>
    )}
    <a
      href={article.url}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm font-medium text-blue-600 hover:text-blue-800"
    >
      원문 보기 →
    </a>
  </div>
</article>

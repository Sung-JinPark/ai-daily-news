---
import { CATEGORIES, loadGlossary, type Article } from "~/lib/loadData";
import { linkifyGlossary } from "~/lib/glossaryLinker";
interface Props {
  article: Article;
  highlight?: boolean;
}
const { article, highlight = false } = Astro.props;
const glossary = loadGlossary();
const summaryHtml = linkifyGlossary(article.summary_ko, glossary);
const publishedLabel = article.published
  ? new Date(article.published).toLocaleString("ko-KR", { month: "long", day: "numeric", hour: "2-digit", minute: "2-digit" })
  : "발행시각 미상";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<article
  class:list={[
    "py-6 border-b border-ink/15 flex flex-col gap-3",
    highlight && "bg-accent/[0.03] -mx-4 px-4",
  ]}
  data-category={article.category}
  data-source={article.source_id}
>
  <div class="flex items-center justify-between text-[11px] tracking-kicker uppercase font-semibold text-ink/60 flex-wrap gap-2">
    <span class="inline-flex items-center gap-2 flex-wrap">
      <a href={`${base}/category/${article.category}`} class="text-accent hover:underline">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <span class="text-ink/30">·</span>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-ink">
        {article.source_name}
      </a>
      <span class="text-ink/30">·</span>
      <span class="normal-case tracking-normal font-normal text-ink/50">{publishedLabel}</span>
    </span>
    <span class="text-accent" title={`중요도 ${article.importance_score}`}>
      {"★".repeat(article.importance_score)}
    </span>
  </div>

  <h3 class="font-serif text-2xl font-black leading-[1.15] text-ink">
    <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
      {article.title_original}
    </a>
  </h3>

  <p class="text-[15px] text-ink/75 leading-relaxed" set:html={summaryHtml}></p>

  {article.insights_ko?.length > 0 && (
    <ul class="text-[14px] text-ink/80 list-disc list-outside ml-5 space-y-1.5 marker:text-accent">
      {article.insights_ko.map((i) => <li>{i}</li>)}
    </ul>
  )}

  {(article.tags && article.tags.length > 0) && (
    <div class="flex flex-wrap gap-x-3 gap-y-1 text-[10px] tracking-kicker uppercase font-semibold">
      {article.tags.slice(0, 5).map((t) => (
        <a
          href={`${base}/topic/${encodeURIComponent(t)}`}
          class="text-ink/60 hover:text-accent"
        >#{t}</a>
      ))}
    </div>
  )}

  {article.also_covered_by?.length > 0 && (
    <span class="text-[11px] tracking-kicker uppercase font-semibold text-ink/50">
      다른 매체 {article.also_covered_by.length}곳
    </span>
  )}
</article>

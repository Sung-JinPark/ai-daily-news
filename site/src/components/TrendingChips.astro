---
import type { TrendingItem } from "~/lib/loadData";
interface Props {
  items: TrendingItem[];
}
const { items } = Astro.props;
---
{items.length > 0 && (
  <div class="mb-6">
    <h2 class="text-xs uppercase tracking-wider text-slate-500 mb-2">트렌딩 키워드</h2>
    <div class="flex flex-wrap gap-2">
      {items.slice(0, 12).map((t) => (
        <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-700 border border-slate-200">
          {t.keyword} <span class="text-slate-400">·{t.count}</span>
        </span>
      ))}
    </div>
  </div>
)}

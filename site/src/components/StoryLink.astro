---
import { clusterSlug, storyPageExists, type Article } from "~/lib/loadData";
interface Props {
  article: Article;
  size?: "sm" | "md";
}
const { article, size = "md" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Only render if the story is worth exploring AND its page will
// actually be built (AUD-004: same eligibility as getStaticPaths —
// otherwise this emits dangling /story/s-* links).
const worth = (article.cluster_size ?? 1) > 1 && storyPageExists(article.cluster_id);
const tCls = size === "sm"
  ? "text-[10px]"
  : "text-[11px]";
// X1: prefer the content-hash slug when the continuity entry has been
// backfilled. Falls back to the legacy k-id for clusters born after
// the backfill or missing entries.
const slug = clusterSlug(article.cluster_id);
---
{worth && (
  <a
    href={`${base}/story/${slug}`}
    class:list={["inline-flex items-center gap-1 tracking-kicker uppercase font-semibold text-accent hover:underline", tCls]}
    aria-label={`이 스토리 전체 보기 — ${article.cluster_size}개 매체`}
  >
    스토리 · {article.cluster_size}개 매체 →
  </a>
)}

---
import { CATEGORIES, loadGlossary, type Article } from "~/lib/loadData";
import { linkifyGlossary } from "~/lib/glossaryLinker";
interface Props {
  article: Article;
  rank?: number;
  size?: "lg" | "md" | "sm";
}
const { article, rank, size = "md" } = Astro.props;
const glossary = loadGlossary();
const summaryHtml = linkifyGlossary(article.summary_ko, glossary);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const aspect = "aspect-[16/9]";
const titleSize = size === "lg" ? "text-xl sm:text-2xl" : size === "sm" ? "text-base" : "text-lg";
const showSummary = size !== "sm";

// institution/authors: use stored values or derive from source
let institution = article.institution || "";
let authors = article.authors || "";
if (!institution && article.category === "model_research") {
  if (article.source_id === "deepmind_blog") institution = "Google DeepMind";
  else if (article.source_id === "openai_news") institution = "OpenAI";
  else if (article.source_id === "huggingface_blog") {
    const m = article.url.match(/huggingface\.co\/blog\/([^/]+)\/[^/]+/);
    if (m) institution = m[1].replace(/-/g, " ");
  }
}
---
<article
  class="group rounded-lg border border-slate-200 bg-white hover:shadow-md transition-shadow flex flex-col"
  data-category={article.category}
  data-source={article.source_id}
>
  <a href={article.url} target="_blank" rel="noopener noreferrer" class={`block ${aspect} bg-slate-100 overflow-hidden rounded-t-lg relative`}>
    {article.image_url ? (
      <>
        <img
          src={article.image_url}
          alt=""
          referrerpolicy="no-referrer"
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div style="display:none" class="w-full h-full flex items-center justify-center text-slate-300 text-5xl">📰</div>
      </>
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-300 text-5xl">📰</div>
    )}
    {rank && (
      <span class="absolute top-2 left-2 px-2 py-0.5 rounded bg-rose-600 text-white text-xs font-bold">
        #{rank}
      </span>
    )}
  </a>
  <div class="p-4 flex-1 flex flex-col gap-2">
    <div class="flex items-center gap-2 text-xs text-slate-500 flex-wrap">
      <a href={`${base}/category/${article.category}`} class="px-1.5 py-0.5 rounded bg-slate-100 hover:bg-slate-200 text-slate-700">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-slate-700 truncate">{article.source_name}</a>
    </div>
    <h3 class={`${titleSize} font-semibold leading-snug text-slate-900`}>
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:underline">
        {article.title_original}
      </a>
    </h3>
    {article.category === "model_research" && (institution || authors) && (
      <p class="text-xs text-indigo-600 leading-snug">
        {institution && <span class="font-medium">{institution}</span>}
        {institution && authors && <span class="text-slate-400"> · </span>}
        {authors && <span>{authors}</span>}
      </p>
    )}
    {(article.tags && article.tags.length > 0) && (
      <div class="flex flex-wrap gap-1">
        {article.tags.slice(0, 3).map((t) => (
          <a
            href={`${base}/topic/${encodeURIComponent(t)}`}
            class="text-[10px] px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-700 hover:bg-indigo-100"
          >#{t}</a>
        ))}
      </div>
    )}
    {showSummary && (
      <div class="group/tip relative">
        <p class="text-sm text-slate-600 line-clamp-3 cursor-default" set:html={summaryHtml}></p>
        <div class="invisible opacity-0 group-hover/tip:visible group-hover/tip:opacity-100
                    absolute left-0 top-full mt-2 z-[200] w-72
                    rounded-lg border border-slate-200 bg-white p-3 shadow-2xl
                    text-sm text-slate-700 leading-relaxed transition-opacity duration-150
                    select-text cursor-text
                    before:content-[''] before:absolute before:-top-2 before:left-0 before:right-0 before:h-2"
             set:html={summaryHtml}></div>
      </div>
    )}
  </div>
</article>

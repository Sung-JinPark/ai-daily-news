---
import { CATEGORIES, loadGlossary, type Article } from "~/lib/loadData";
import { linkifyGlossary } from "~/lib/glossaryLinker";
interface Props {
  article: Article;
  rank?: number;
  size?: "lg" | "md" | "sm";
}
const { article, rank, size = "md" } = Astro.props;
const glossary = loadGlossary();
const summaryHtml = linkifyGlossary(article.summary_ko, glossary);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const aspect = "aspect-[16/9]";
const titleSize = size === "lg" ? "text-xl sm:text-2xl" : size === "sm" ? "text-base" : "text-lg";
const showSummary = size !== "sm";

let institution = article.institution || "";
let authors = article.authors || "";
if (!institution && article.category === "model_research") {
  if (article.source_id === "deepmind_blog") institution = "Google DeepMind";
  else if (article.source_id === "openai_news") institution = "OpenAI";
  else if (article.source_id === "huggingface_blog") {
    const m = article.url.match(/huggingface\.co\/blog\/([^/]+)\/[^/]+/);
    if (m) institution = m[1].replace(/-/g, " ");
  }
}
---
<article
  class="group flex flex-col gap-3 pb-5 border-b border-ink/15"
  data-category={article.category}
  data-source={article.source_id}
>
  <a href={article.url} target="_blank" rel="noopener noreferrer" class={`block ${aspect} bg-ink/5 overflow-hidden relative`}>
    {article.image_url ? (
      <>
        <img
          src={article.image_url}
          alt=""
          referrerpolicy="no-referrer"
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div style="display:none" class="w-full h-full flex items-center justify-center font-serif text-ink/20 text-5xl">A</div>
      </>
    ) : (
      <div class="w-full h-full flex items-center justify-center font-serif text-ink/20 text-5xl">A</div>
    )}
    {rank && (
      <span class="absolute top-0 left-0 bg-accent text-white font-serif font-black text-base px-2.5 py-1">
        {String(rank).padStart(2, "0")}
      </span>
    )}
  </a>
  <div class="flex flex-col gap-2">
    <div class="flex items-center gap-2 text-[10px] tracking-kicker uppercase font-semibold text-ink/60">
      <a href={`${base}/category/${article.category}`} class="text-accent hover:underline">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <span class="text-ink/30">·</span>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-ink truncate">{article.source_name}</a>
    </div>
    <h3 class={`font-serif ${titleSize} font-bold leading-tight text-ink`}>
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
        {article.title_original}
      </a>
    </h3>
    {article.category === "model_research" && (institution || authors) && (
      <p class="text-xs text-ink/60 leading-snug">
        {institution && <span class="font-semibold text-ink/80">{institution}</span>}
        {institution && authors && <span class="text-ink/30"> · </span>}
        {authors && <span>{authors}</span>}
      </p>
    )}
    {(article.tags && article.tags.length > 0) && (
      <div class="flex flex-wrap gap-x-2 gap-y-1 text-[10px] tracking-kicker uppercase font-semibold">
        {article.tags.slice(0, 3).map((t) => (
          <a
            href={`${base}/topic/${encodeURIComponent(t)}`}
            class="text-ink/60 hover:text-accent"
          >#{t}</a>
        ))}
      </div>
    )}
    {showSummary && (
      <div class="group/tip relative">
        <p class="text-sm text-ink/70 leading-relaxed line-clamp-3 cursor-default" set:html={summaryHtml}></p>
        <div class="invisible opacity-0 group-hover/tip:visible group-hover/tip:opacity-100
                    absolute left-0 top-full mt-2 z-[200] w-72
                    border border-ink bg-white p-3 shadow-[4px_4px_0_0_rgba(10,10,10,0.06)]
                    text-sm text-ink/80 leading-relaxed transition-opacity duration-150
                    select-text cursor-text
                    before:content-[''] before:absolute before:-top-2 before:left-0 before:right-0 before:h-2"
             set:html={summaryHtml}></div>
      </div>
    )}
  </div>
</article>

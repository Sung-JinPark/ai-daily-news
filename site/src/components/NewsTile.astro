---
import { CATEGORIES, type Article } from "~/lib/loadData";
interface Props {
  article: Article;
  rank?: number;
  size?: "lg" | "md" | "sm";
}
const { article, rank, size = "md" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const aspect = size === "lg" ? "aspect-[16/9]" : size === "sm" ? "aspect-[16/9]" : "aspect-[16/9]";
const titleSize = size === "lg" ? "text-xl sm:text-2xl" : size === "sm" ? "text-base" : "text-lg";
const showSummary = size !== "sm";
---
<article
  class="group rounded-lg overflow-hidden border border-slate-200 bg-white hover:shadow-md transition-shadow flex flex-col"
  data-category={article.category}
  data-source={article.source_id}
>
  <a href={article.url} target="_blank" rel="noopener noreferrer" class={`block ${aspect} bg-slate-100 overflow-hidden relative`}>
    {article.image_url ? (
      <img
        src={article.image_url}
        alt=""
        referrerpolicy="no-referrer"
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-300 text-5xl">📰</div>
    )}
    {rank && (
      <span class="absolute top-2 left-2 px-2 py-0.5 rounded bg-rose-600 text-white text-xs font-bold">
        #{rank}
      </span>
    )}
  </a>
  <div class="p-4 flex-1 flex flex-col gap-2">
    <div class="flex items-center gap-2 text-xs text-slate-500 flex-wrap">
      <a href={`${base}/category/${article.category}`} class="px-1.5 py-0.5 rounded bg-slate-100 hover:bg-slate-200 text-slate-700">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-slate-700 truncate">{article.source_name}</a>
    </div>
    <h3 class={`${titleSize} font-semibold leading-snug text-slate-900`}>
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:underline">
        {article.title_original}
      </a>
    </h3>
    {showSummary && (
      <p class="text-sm text-slate-600 line-clamp-3">{article.summary_ko}</p>
    )}
  </div>
</article>

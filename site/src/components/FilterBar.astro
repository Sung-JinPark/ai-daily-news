---
import { CATEGORIES } from "~/lib/loadData";
interface Props {
  sources: { id: string; name: string }[];
  days: string[];
  currentDay: string;
}
const { sources, days, currentDay } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<div class="grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-3 mb-8 pb-4 border-b border-ink/15">
  <label class="block">
    <span class="kicker text-ink/55 block mb-1">카테고리</span>
    <select
      id="filter-category"
      class="w-full bg-transparent border-0 border-b border-ink/30 px-0 py-1.5 text-sm text-ink focus:outline-none focus:border-accent"
    >
      <option value="">모든 카테고리</option>
      {Object.entries(CATEGORIES).map(([k, label]) => (
        <option value={k}>{label}</option>
      ))}
    </select>
  </label>

  <label class="block">
    <span class="kicker text-ink/55 block mb-1">매체</span>
    <select
      id="filter-source"
      class="w-full bg-transparent border-0 border-b border-ink/30 px-0 py-1.5 text-sm text-ink focus:outline-none focus:border-accent"
    >
      <option value="">모든 매체</option>
      {sources.map((s) => <option value={s.id}>{s.name}</option>)}
    </select>
  </label>

  <label class="block">
    <span class="kicker text-ink/55 block mb-1">날짜</span>
    <select
      id="filter-day"
      class="w-full bg-transparent border-0 border-b border-ink/30 px-0 py-1.5 text-sm text-ink focus:outline-none focus:border-accent tabular-nums"
      data-base={base}
    >
      {days.map((d) => (
        <option value={d} selected={d === currentDay}>{d}</option>
      ))}
    </select>
  </label>
</div>

<script is:inline>
  (function () {
    const cat = document.getElementById("filter-category");
    const src = document.getElementById("filter-source");
    const day = document.getElementById("filter-day");

    function apply() {
      const c = cat?.value || "";
      const s = src?.value || "";
      document.querySelectorAll("[data-category]").forEach((el) => {
        const matchC = !c || el.getAttribute("data-category") === c;
        const matchS = !s || el.getAttribute("data-source") === s;
        el.style.display = matchC && matchS ? "" : "none";
      });
    }
    cat?.addEventListener("change", apply);
    src?.addEventListener("change", apply);
    day?.addEventListener("change", () => {
      const base = day.dataset.base || "";
      const v = day.value;
      window.location.href = `${base}/archive/${v}`;
    });
  })();
</script>

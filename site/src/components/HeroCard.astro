---
import { CATEGORIES, loadGlossary, type Article } from "~/lib/loadData";
import { linkifyGlossary } from "~/lib/glossaryLinker";
interface Props {
  article: Article;
}
const { article } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const publishedLabel = article.published
  ? new Date(article.published).toLocaleString("ko-KR")
  : "";
const glossary = loadGlossary();
const summaryHtml = linkifyGlossary(article.summary_ko, glossary);
---
<section
  class="rounded-xl overflow-hidden border border-slate-200 bg-white mb-10 shadow-sm"
  data-category={article.category}
  data-source={article.source_id}
>
  {article.image_url && (
    <a href={article.url} target="_blank" rel="noopener noreferrer" class="block aspect-[16/7] bg-slate-100 overflow-hidden">
      <img
        src={article.image_url}
        alt=""
        referrerpolicy="no-referrer"
        loading="eager"
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
        onerror="this.closest('a').style.display='none'"
      />
    </a>
  )}

  <div class="p-6 sm:p-8">
    <div class="flex items-center gap-2 text-xs uppercase tracking-wider text-rose-600 font-semibold mb-3">
      <span class="px-2 py-0.5 rounded bg-rose-50">오늘의 1순위</span>
      <span class="text-amber-500 normal-case tracking-normal">{"★".repeat(article.importance_score)}</span>
    </div>

    <h2 class="text-2xl sm:text-3xl font-bold leading-tight text-slate-900 mb-2">
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:underline">
        {article.title_original}
      </a>
    </h2>
    {article.subtitle_en && (
      <p class="text-sm italic text-slate-500 mb-3">{article.subtitle_en}</p>
    )}

    <div class="flex items-center gap-2 text-xs text-slate-500 mb-4 flex-wrap">
      <a href={`${base}/category/${article.category}`} class="px-2 py-0.5 rounded bg-slate-100 hover:bg-slate-200 text-slate-700">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-slate-700">{article.source_name}</a>
      {publishedLabel && <><span class="text-slate-300">·</span><span>{publishedLabel}</span></>}
      {article.cluster_size > 1 && (
        <><span class="text-slate-300">·</span><span>{article.cluster_size}개 매체 보도</span></>
      )}
    </div>

    <p class="text-base text-slate-700 leading-relaxed mb-4" set:html={summaryHtml}></p>

    {article.insights_ko?.length > 0 && (
      <ul class="text-sm text-slate-800 list-disc list-outside ml-5 space-y-1.5 mb-5">
        {article.insights_ko.map((i) => <li>{i}</li>)}
      </ul>
    )}

    <div class="flex items-center gap-3 flex-wrap">
      <a
        href={article.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 px-4 py-2 rounded-md bg-slate-900 text-white text-sm font-medium hover:bg-slate-700"
      >
        원문 보기 →
      </a>
      <button
        type="button"
        class="share-btn inline-flex items-center gap-1 px-4 py-2 rounded-md border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50"
        data-share-title={article.title_original}
        data-share-text={article.subtitle_en || article.summary_ko.slice(0, 140)}
        data-share-url={article.url}
      >공유</button>
    </div>
  </div>
</section>

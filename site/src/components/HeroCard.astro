---
import { CATEGORIES, loadGlossary, type Article } from "~/lib/loadData";
import { linkifyGlossary } from "~/lib/glossaryLinker";
interface Props {
  article: Article;
}
const { article } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const publishedLabel = article.published
  ? new Date(article.published).toLocaleDateString("ko-KR", { month: "long", day: "numeric" })
  : "";
const glossary = loadGlossary();
const summaryHtml = linkifyGlossary(article.summary_ko, glossary);
---
<section
  class="mb-12 grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 pb-10 border-b-2 border-ink"
  data-category={article.category}
  data-source={article.source_id}
>
  {article.image_url && (
    <a href={article.url} target="_blank" rel="noopener noreferrer" class="block lg:col-span-7 aspect-[16/9] bg-ink/5 overflow-hidden group">
      <img
        src={article.image_url}
        alt=""
        referrerpolicy="no-referrer"
        loading="eager"
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700"
        onerror="this.closest('a').style.display='none'"
      />
    </a>
  )}

  <div class={article.image_url ? "lg:col-span-5 flex flex-col" : "lg:col-span-12 flex flex-col"}>
    <div class="kicker text-accent mb-3">오늘의 1순위 · 핵심 보도</div>

    <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.05] text-ink mb-3">
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">
        {article.title_original}
      </a>
    </h2>

    {article.subtitle_en && (
      <p class="font-serif italic text-base text-ink/55 leading-snug mb-4">{article.subtitle_en}</p>
    )}

    <div class="flex items-center gap-3 text-[11px] tracking-kicker uppercase font-semibold text-ink/70 mb-5 flex-wrap">
      <a href={`${base}/category/${article.category}`} class="text-accent hover:underline">
        {CATEGORIES[article.category] ?? article.category}
      </a>
      <span class="text-ink/30">·</span>
      <a href={`${base}/source/${article.source_id}`} class="hover:text-ink">{article.source_name}</a>
      {publishedLabel && <><span class="text-ink/30">·</span><span>{publishedLabel}</span></>}
      {article.cluster_size > 1 && (
        <><span class="text-ink/30">·</span><span>{article.cluster_size}개 매체</span></>
      )}
    </div>

    <p class="text-[16px] sm:text-[17px] text-ink/80 leading-relaxed mb-5" set:html={summaryHtml}></p>

    {article.insights_ko?.length > 0 && (
      <ul class="text-[15px] text-ink/85 list-disc list-outside ml-5 space-y-2 mb-6 marker:text-accent">
        {article.insights_ko.map((i) => <li>{i}</li>)}
      </ul>
    )}

    <a
      href={article.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 self-start px-5 py-2.5 bg-ink text-white text-[12px] tracking-kicker uppercase font-bold hover:bg-accent transition-colors"
    >
      원문 보기 →
    </a>
  </div>
</section>

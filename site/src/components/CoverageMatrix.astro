---
import { CATEGORIES, type CoverageMatrix } from "~/lib/loadData";
interface Props {
  matrix: CoverageMatrix;
}
const { matrix } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const CATEGORY_COLOR: Record<string, string> = {
  model_research: "#be1622",
  business: "#0369a1",
  policy: "#7c3aed",
  product: "#059669",
  hardware: "#d97706",
  community: "#64748b",
};

// Presence lookup: `${outlet}\u0001${cluster_id}` → importance
const cellMap = new Map<string, number>();
for (const c of matrix.cells) {
  cellMap.set(`${c.outlet}\u0001${c.cluster_id}`, c.importance);
}

function shortTitle(t: string, max = 42): string {
  return t.length > max ? t.slice(0, max - 1) + "…" : t;
}
---
{matrix.clusters.length > 0 && matrix.outlets.length > 0 && (
  <div class="overflow-x-auto -mx-4 px-4">
    <table class="text-[11px] border-collapse min-w-full">
      <thead>
        <tr>
          <th class="sticky left-0 bg-white z-[2] text-left kicker text-ink/50 pr-3 pb-3 align-bottom">매체 \ 스토리</th>
          {matrix.clusters.map((c) => (
            <th class="align-bottom py-2 pr-2 whitespace-nowrap" style="min-width:2rem">
              <a
                href={`${base}/story/${c.cluster_id}`}
                class="inline-block origin-bottom-left -rotate-45 translate-y-1 text-ink/70 hover:text-accent text-[11px] font-medium"
                title={c.title}
              >
                {shortTitle(c.title, 34)}
              </a>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {matrix.outlets.map((outlet) => (
          <tr class="border-t border-ink/10">
            <td class="sticky left-0 bg-white z-[1] py-2 pr-3 text-ink/75 font-medium whitespace-nowrap">{outlet}</td>
            {matrix.clusters.map((c) => {
              const imp = cellMap.get(`${outlet}\u0001${c.cluster_id}`);
              const color = CATEGORY_COLOR[c.category] ?? "#64748b";
              const size = imp ? Math.min(14, 5 + imp * 2) : 0;
              return (
                <td class="py-2 pr-2 text-center align-middle">
                  {imp ? (
                    <a
                      href={`${base}/story/${c.cluster_id}`}
                      class="inline-block rounded-full hover:opacity-80"
                      style={`width:${size}px;height:${size}px;background:${color}`}
                      title={`${outlet} · ${CATEGORIES[c.category] ?? c.category} · 중요도 ${imp}`}
                      aria-label={`${outlet}이(가) ${c.title} 스토리를 다뤘습니다`}
                    ></a>
                  ) : (
                    <span class="inline-block w-1 h-1 bg-ink/10 rounded-full" aria-hidden="true"></span>
                  )}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-[10px] tracking-kicker uppercase font-semibold text-ink/60">
      <span>범례</span>
      {Object.entries(CATEGORY_COLOR).map(([k, color]) => (
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block w-2 h-2 rounded-full" style={`background:${color}`}></span>
          <span>{CATEGORIES[k] ?? k}</span>
        </span>
      ))}
      <span class="text-ink/40">· 점의 크기 = 중요도</span>
    </div>
  </div>
)}

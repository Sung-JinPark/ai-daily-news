---
import { CATEGORIES } from "~/lib/loadData";
interface Props {
  title?: string;
  description?: string;
  updatedAt?: string;
  ogImage?: string;
}
const DEFAULT_DESC = "매일 자동 업데이트되는 글로벌 AI 뉴스 한국어 인사이트 대시보드";
const { title = "AI Daily News", description = DEFAULT_DESC, updatedAt, ogImage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

const today = new Date();
const datelineEn = today.toLocaleDateString("ko-KR", {
  timeZone: "Asia/Seoul",
  year: "numeric",
  month: "long",
  day: "numeric",
  weekday: "long",
});
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' fill='%23be1622'/%3E%3Ctext x='32' y='44' text-anchor='middle' fill='white' font-family='Georgia' font-weight='700' font-size='36'%3EA%3C/text%3E%3C/svg%3E" />
    <link rel="alternate" type="application/rss+xml" title="AI Daily News RSS" href={`${base}/rss.xml`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@500;700;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    {googleVerification && (
      <meta name="google-site-verification" content={googleVerification} />
    )}
    <title>{title}</title>
    <style is:global>
      body { font-feature-settings: "ss01", "cv11"; }
      .gl {
        border-bottom: 1px dotted #94a3b8;
        cursor: help;
      }
      .gl:hover {
        background-color: rgba(190, 22, 34, 0.06);
        border-bottom-color: #be1622;
      }
      #gl-tip {
        position: fixed;
        display: none;
        z-index: 9999;
        max-width: 20rem;
        padding: 0.875rem 1rem;
        background: white;
        border: 1px solid #0a0a0a;
        border-radius: 2px;
        box-shadow: 4px 4px 0 0 rgba(10, 10, 10, 0.06);
        font-size: 0.875rem;
        color: #1a1a1a;
        line-height: 1.55;
        pointer-events: none;
      }
      #gl-tip .gl-tip-term {
        font-weight: 700;
        color: #be1622;
      }
      #gl-tip .gl-tip-full {
        font-weight: 400;
        font-size: 0.75rem;
        color: #6b7280;
        margin-left: 0.25rem;
      }
      #gl-tip .gl-tip-desc {
        margin-top: 0.375rem;
      }
      .kicker {
        font-size: 0.6875rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 700;
      }
      .rule-thick { border-top: 3px solid #0a0a0a; }
      .rule-thin  { border-top: 1px solid #d1d5db; }
      /* Hide horizontal scrollbar on the nav while keeping touch/scroll behavior */
      .no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
      .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
  </head>
  <body class="min-h-screen bg-white text-ink antialiased selection:bg-accent/20">
    <header class="border-b-2 border-ink bg-white">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex items-center justify-between pt-4 pb-1 text-[11px] tracking-kicker uppercase font-semibold text-ink/70">
          <span>{datelineEn}</span>
          {updatedAt ? (
            <span>업데이트 {new Date(updatedAt).toLocaleString("ko-KR", { timeZone: "Asia/Seoul", month: "2-digit", day: "2-digit", hour: "2-digit", minute: "2-digit" })}</span>
          ) : <span />}
        </div>
        <a href={import.meta.env.BASE_URL} class="block text-center pt-2 pb-4 group">
          <span class="block font-serif text-4xl sm:text-5xl font-black tracking-tight leading-[1.05] text-ink group-hover:text-accent transition-colors">AI Daily News</span>
          <span class="block mt-3 text-[11px] tracking-kicker uppercase text-ink/60">JIN's studyground</span>
        </a>
      </div>
      <nav class="border-t border-ink/15 bg-white sticky top-0 z-10">
        <div class="max-w-6xl mx-auto px-4 flex items-stretch gap-0 overflow-x-auto no-scrollbar">
          <a href={base + "/"} class="px-3 py-2.5 text-[12px] tracking-kicker uppercase font-semibold text-accent border-b-2 border-transparent hover:border-accent whitespace-nowrap">HOT</a>
          <a href={`${base}/today`} class="px-3 py-2.5 text-[12px] tracking-kicker uppercase font-semibold text-ink/80 border-b-2 border-transparent hover:border-ink whitespace-nowrap">전체</a>
          <a href={`${base}/category/model_research`} class="px-3 py-2.5 text-[12px] tracking-kicker uppercase font-semibold text-ink/80 border-b-2 border-transparent hover:border-ink whitespace-nowrap">{CATEGORIES.model_research}</a>
          <a href={`${base}/category/business`} class="px-3 py-2.5 text-[12px] tracking-kicker uppercase font-semibold text-ink/80 border-b-2 border-transparent hover:border-ink whitespace-nowrap">{CATEGORIES.business}</a>
          <a href={`${base}/category/policy`} class="px-3 py-2.5 text-[12px] tracking-kicker uppercase font-semibold text-ink/80 border-b-2 border-transparent hover:border-ink whitespace-nowrap">{CATEGORIES.policy}</a>
          <a href={`${base}/category/tech`} class="px-3 py-2.5 text-[12px] tracking-kicker uppercase font-semibold text-ink/80 border-b-2 border-transparent hover:border-ink whitespace-nowrap">제품/인프라</a>
          <a href={`${base}/category/community`} class="px-3 py-2.5 text-[12px] tracking-kicker uppercase font-semibold text-ink/80 border-b-2 border-transparent hover:border-ink whitespace-nowrap">{CATEGORIES.community}</a>
          <span class="self-center mx-2 h-4 w-px bg-ink/20" aria-hidden="true"></span>
          <a href={`${base}/insights`} class="px-2.5 py-2.5 text-[12.5px] font-serif italic font-medium text-ink/55 hover:text-accent whitespace-nowrap">인사이트</a>
          <a href={`${base}/entities`} class="px-2.5 py-2.5 text-[12.5px] font-serif italic font-medium text-ink/55 hover:text-accent whitespace-nowrap">엔티티</a>
          <a href={`${base}/weekly`} class="px-2.5 py-2.5 text-[12.5px] font-serif italic font-medium text-ink/55 hover:text-accent whitespace-nowrap">주간</a>
          <a href={`${base}/archive`} class="px-2.5 py-2.5 text-[12.5px] font-serif italic font-medium text-ink/55 hover:text-accent whitespace-nowrap ml-auto">아카이브</a>
          <form action={`${base}/search`} method="get" role="search" class="self-center ml-3 flex items-center border border-ink/25 focus-within:border-ink px-2 py-1 bg-white">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="w-3.5 h-3.5 text-ink/50 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
            <input
              type="search"
              name="q"
              placeholder="검색"
              aria-label="전체 검색"
              class="ml-1.5 w-24 sm:w-32 bg-transparent border-0 text-[12.5px] text-ink placeholder:text-ink/40 focus:outline-none"
            />
          </form>
        </div>
      </nav>
    </header>
    <main class="max-w-6xl mx-auto px-4 py-10">
      <slot />
    </main>
    <script is:inline>
      (function () {
        if (window.__glTipInit) return;
        window.__glTipInit = true;
        var tip = document.createElement("div");
        tip.id = "gl-tip";
        document.body.appendChild(tip);

        function show(el) {
          var full = el.getAttribute("data-full") || "";
          var desc = el.getAttribute("data-desc") || "";
          var term = el.textContent || "";
          tip.innerHTML =
            '<div><span class="gl-tip-term"></span><span class="gl-tip-full"></span></div>' +
            '<div class="gl-tip-desc"></div>';
          tip.querySelector(".gl-tip-term").textContent = term;
          tip.querySelector(".gl-tip-full").textContent = full;
          tip.querySelector(".gl-tip-desc").textContent = desc;
          tip.style.display = "block";
          var r = el.getBoundingClientRect();
          var w = tip.offsetWidth;
          var h = tip.offsetHeight;
          var left = r.left;
          var top = r.bottom + 6;
          if (top + h > window.innerHeight - 8) top = r.top - h - 6;
          if (left + w > window.innerWidth - 8) left = window.innerWidth - w - 8;
          tip.style.left = Math.max(8, left) + "px";
          tip.style.top = Math.max(8, top) + "px";
        }
        function hide() { tip.style.display = "none"; }

        document.addEventListener("mouseover", function (e) {
          var el = e.target && e.target.closest && e.target.closest(".gl");
          if (el) show(el);
        });
        document.addEventListener("mouseout", function (e) {
          var el = e.target && e.target.closest && e.target.closest(".gl");
          if (el) hide();
        });
        document.addEventListener("scroll", hide, { passive: true });
      })();
    </script>
    <footer class="border-t-2 border-ink mt-20">
      <div class="max-w-6xl mx-auto px-4 py-8 text-[11px] tracking-kicker uppercase font-semibold text-ink/60 flex flex-col sm:flex-row gap-3 justify-between">
        <span>All articles © their respective publishers · All rights reserved</span>
        <a href="https://github.com/Sung-JinPark/ai-daily-news" target="_blank" rel="noopener" class="hover:text-accent font-mono normal-case tracking-normal">JP's AI-DAILY-NEWS</a>
      </div>
    </footer>
  </body>
</html>

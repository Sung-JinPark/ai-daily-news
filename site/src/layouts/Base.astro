---
import { CATEGORIES } from "~/lib/loadData";
interface Props {
  title?: string;
  description?: string;
  updatedAt?: string;
  ogImage?: string;
}
const DEFAULT_DESC = "매일 자동 업데이트되는 글로벌 AI 뉴스 한국어 인사이트 대시보드";
const { title = "AI Daily News", description = DEFAULT_DESC, updatedAt, ogImage } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const googleVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Ctext y='52' font-size='52'%3E🤖%3C/text%3E%3C/svg%3E" />
    <link rel="alternate" type="application/rss+xml" title="AI Daily News RSS" href={`${base}/rss.xml`} />
    {googleVerification && (
      <meta name="google-site-verification" content={googleVerification} />
    )}
    <title>{title}</title>
    <style is:global>
      .gl {
        border-bottom: 1px dotted #6366f1;
        cursor: help;
      }
      .gl:hover {
        background-color: rgba(99, 102, 241, 0.08);
      }
      #gl-tip {
        position: fixed;
        display: none;
        z-index: 9999;
        max-width: 20rem;
        padding: 0.75rem 0.875rem;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
        font-size: 0.875rem;
        color: #334155;
        line-height: 1.55;
        pointer-events: none;
      }
      #gl-tip .gl-tip-term {
        font-weight: 700;
        color: #4338ca;
      }
      #gl-tip .gl-tip-full {
        font-weight: 400;
        font-size: 0.75rem;
        color: #94a3b8;
        margin-left: 0.25rem;
      }
      #gl-tip .gl-tip-desc {
        margin-top: 0.25rem;
      }
    </style>
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased selection:bg-amber-100">
    <header class="border-b border-slate-200 sticky top-0 bg-white/85 backdrop-blur z-10">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between gap-3 flex-wrap">
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 shrink-0">
          <span class="text-xl font-bold tracking-tight text-slate-900">AI Daily News</span>
          <span class="text-xs text-slate-500 hidden sm:inline">한국어 인사이트</span>
        </a>
        {updatedAt && (
          <span class="text-xs text-slate-500 shrink-0">
            업데이트 {new Date(updatedAt).toLocaleString("ko-KR")}
          </span>
        )}
      </div>
      <nav class="max-w-6xl mx-auto px-4 pb-3 flex gap-1 flex-wrap text-sm overflow-x-auto">
        <a href={base + "/"} class="px-3 py-1 rounded-md text-slate-700 hover:bg-slate-100">전체</a>
        <a href={`${base}/hot`} class="px-3 py-1 rounded-md text-rose-600 hover:bg-rose-50 font-medium whitespace-nowrap" title="지난 7일 핵심">🔥 HOT</a>
        {Object.entries(CATEGORIES).map(([slug, label]) => (
          <a
            href={`${base}/category/${slug}`}
            class="px-3 py-1 rounded-md text-slate-700 hover:bg-slate-100 whitespace-nowrap"
          >
            {label}
          </a>
        ))}
        <a href={`${base}/topic`} class="px-3 py-1 rounded-md text-indigo-700 hover:bg-indigo-50 whitespace-nowrap" title="토픽별 보기">#토픽</a>
        <a href={`${base}/players`} class="px-3 py-1 rounded-md text-indigo-700 hover:bg-indigo-50 whitespace-nowrap" title="플레이어별 활동">🏢 플레이어</a>
        <a href={`${base}/weekly`} class="px-3 py-1 rounded-md text-indigo-700 hover:bg-indigo-50 whitespace-nowrap" title="주간 다이제스트">📅 주간</a>
        <a href={`${base}/archive`} class="px-3 py-1 rounded-md text-slate-700 hover:bg-slate-100 ml-auto">아카이브</a>
        <a href={`${base}/rss.xml`} class="px-3 py-1 rounded-md text-orange-600 hover:bg-orange-50" title="RSS 구독">RSS</a>
      </nav>
    </header>
    <main class="max-w-6xl mx-auto px-4 py-8">
      <slot />
    </main>
    <script is:inline>
      (function () {
        if (window.__glTipInit) return;
        window.__glTipInit = true;
        var tip = document.createElement("div");
        tip.id = "gl-tip";
        document.body.appendChild(tip);

        function show(el) {
          var full = el.getAttribute("data-full") || "";
          var desc = el.getAttribute("data-desc") || "";
          var term = el.textContent || "";
          tip.innerHTML =
            '<div><span class="gl-tip-term"></span><span class="gl-tip-full"></span></div>' +
            '<div class="gl-tip-desc"></div>';
          tip.querySelector(".gl-tip-term").textContent = term;
          tip.querySelector(".gl-tip-full").textContent = full;
          tip.querySelector(".gl-tip-desc").textContent = desc;
          tip.style.display = "block";
          var r = el.getBoundingClientRect();
          var w = tip.offsetWidth;
          var h = tip.offsetHeight;
          var left = r.left;
          var top = r.bottom + 6;
          if (top + h > window.innerHeight - 8) top = r.top - h - 6;
          if (left + w > window.innerWidth - 8) left = window.innerWidth - w - 8;
          tip.style.left = Math.max(8, left) + "px";
          tip.style.top = Math.max(8, top) + "px";
        }
        function hide() { tip.style.display = "none"; }

        document.addEventListener("mouseover", function (e) {
          var el = e.target && e.target.closest && e.target.closest(".gl");
          if (el) show(el);
        });
        document.addEventListener("mouseout", function (e) {
          var el = e.target && e.target.closest && e.target.closest(".gl");
          if (el) hide();
        });
        document.addEventListener("scroll", hide, { passive: true });
      })();
    </script>
    <footer class="border-t border-slate-200 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-6 text-xs text-slate-500 flex flex-col sm:flex-row gap-2 justify-between">
        <span>요약·인사이트 by Claude Haiku 4.5. 원문 저작권은 각 매체에 있습니다.</span>
        <span>본문 미저장 · 원문 링크로 이동하세요 · <a href="https://github.com/Sung-JinPark/ai-daily-news" target="_blank" rel="noopener" class="hover:text-slate-700 font-mono">JP/AI-DAILY-NEWS</a></span>
      </div>
    </footer>
  </body>
</html>

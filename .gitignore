# Secrets
.env
.env.local

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# Pipeline transient state (article bodies must NOT be committed)
raw/
.cache/

# Query artifacts — rebuilt by pipeline.build_db from git-tracked JSON/JSONL.
data/archive.db
data/archive.db-journal
data/exports/

# Astro / Node
site/node_modules/
site/dist/
site/.astro/
*.log

# OS
.DS_Store
Thumbs.db

# Atomic-write staging (AUD-016): a crash between tmp-write and rename
# must never leave a file that `git add data/` would sweep into a commit.
*.tmp

# Claude Code local permissions
.claude/settings.local.json

# Local review packages (zips for offline review)
review/

# Research paper private artifacts — NEVER commit.
# Analysis code under pipeline/research/ and docs under research/ ARE
# tracked (reproducibility). Only the accumulated derived data stays
# private so the paper's raw corpus is not exposed pre-publication.
data/research_private/

# Local reference-paper corpus (PDF + metadata + extracted text).
# Same rule as research_private: scaffolded on the researcher's
# machine only, never mirrored to the public git.
data/papers_private/

# DBQ-3 (2026-07-03): article body full text is PRIVATE - never commit.
# Third-party media copyright; research consumes the local files directly.
data/corpus/*/bodies.jsonl
